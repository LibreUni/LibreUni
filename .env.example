# Copy to .env for local use, then replace the placeholder.
# Never commit a real API key.
OPENROUTER_API_KEY=replace-me
LIBREUNI_MODEL=deepseek/deepseek-v4-flash
LIBREUNI_REVIEWER_MODEL=deepseek/deepseek-v4-flash
LIBREUNI_MAX_REVISIONS=3
LIBREUNI_MAX_SOURCES=8
LIBREUNI_FILES_PER_CALL=4
LIBREUNI_API_TIMEOUT_SECONDS=90
LIBREUNI_MAX_OUTPUT_TOKENS=20000
LIBREUNI_REASONING_EFFORT=low
LIBREUNI_REVISION_MODE=edits
