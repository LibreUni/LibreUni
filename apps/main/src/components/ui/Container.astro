---
interface Props {
  id?: string;
  className?: string;
  size?: 'lesson' | 'full' | 'wide';
}

const { id, className = '', size = 'lesson' } = Astro.props;

const sizes = {
  lesson: 'container-lesson',
  full: 'w-full px-4 md:px-6',
  wide: 'max-w-7xl mx-auto px-4 md:px-6'
};
---

<div id={id} class:list={[sizes[size], className]}>
  <slot />
</div>
