---
import { BookOpen, Menu, X, Home, Book, Compass, Users } from '../components/Icons';
import Search from '../components/Search';
import ThemeToggle from '../components/ThemeToggle';
import { DEFAULT_THEME_ID, THEMES } from '../utils/themes';
import 'katex/dist/katex.min.css';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const themeIds = THEMES.map((theme) => theme.id);
const darkThemeIds = THEMES.filter((theme) => theme.prefersDark).map((theme) => theme.id);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Literata:opsz,wght@7..72,400;7..72,500;7..72,600;7..72,700;7..72,800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script is:inline src="https://cdn.jsdelivr.net/pyodide/v0.25.0/full/pyodide.js"></script>
    <script>
      // Force hoisted script generation
      console.log("LibreUni: Production bundle active");
    </script>
    <script is:inline define:vars={{ themeIds, darkThemeIds, defaultThemeId: DEFAULT_THEME_ID }}>
      const storedTheme = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
      const theme = themeIds.includes(storedTheme) ? storedTheme : defaultThemeId;

      document.documentElement.dataset.theme = theme;
      document.documentElement.classList.toggle('dark', darkThemeIds.includes(theme));
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="bg-light-bg dark:bg-dark-bg min-h-screen font-sans text-light-text dark:text-dark-text antialiased scroll-smooth">
    <!-- Top Navigation Bar -->
    <header class="nav-fixed-header bg-light-bg dark:bg-dark-surface border-b border-light-border dark:border-dark-border flex items-center justify-between px-4 md:px-6">
      <div class="flex items-center gap-4 md:gap-8">
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 md:gap-3 group">
            <div class="bg-primary p-1.5 md:p-2 rounded-lg md:rounded-xl shadow-lg shadow-primary/30 transform group-hover:rotate-6 transition-transform">
                <BookOpen size={18} className="text-white md:w-5 md:h-5" />
            </div>
            <span class="text-lg md:text-xl font-black tracking-tighter text-light-text dark:text-dark-text shrink-0">LibreUni</span>
        </a>
        <nav class="hidden md:flex items-center gap-2">
            <a href={import.meta.env.BASE_URL} class="px-4 py-2 hover:bg-light-accent/5 dark:hover:bg-dark-accent/5 rounded-xl text-sm font-bold transition-all">Home</a>
            <a href={`${import.meta.env.BASE_URL}courses`} class="px-4 py-2 hover:bg-light-accent/5 dark:hover:bg-dark-accent/5 rounded-xl text-sm font-bold transition-all">Courses</a>
            <a href={`${import.meta.env.BASE_URL}careers`} class="px-4 py-2 hover:bg-light-accent/5 dark:hover:bg-dark-accent/5 rounded-xl text-sm font-bold transition-all">Career Paths</a>
            <a href={`${import.meta.env.BASE_URL}about`} class="px-4 py-2 hover:bg-light-accent/5 dark:hover:bg-dark-accent/5 rounded-xl text-sm font-bold transition-all">About</a>
        </nav>
      </div>

      <div class="flex items-center gap-2 md:gap-4 flex-1 justify-end">
         <div class="hidden md:block flex-1 max-w-md">
            <Search client:load baseUrl={import.meta.env.BASE_URL} />
         </div>
         <div class="flex items-center gap-1 md:gap-2">
            <ThemeToggle client:load />
            <button 
                id="mobile-menu-toggle"
                class="p-2 md:p-2.5 hover:bg-light-accent/10 dark:hover:bg-dark-accent/10 rounded-xl transition-colors md:hidden text-light-text dark:text-dark-text border border-light-border dark:border-dark-border"
                aria-label="Toggle Menu"
            >
                <span id="menu-icon"><Menu size={20} /></span>
                <span id="close-icon" class="hidden"><X size={20} /></span>
            </button>
         </div>
      </div>
    </header>

    <!-- Mobile Navigation Overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-[90] bg-light-bg dark:bg-dark-bg transition-all duration-500 translate-x-full md:hidden pt-24 px-8 overflow-y-auto pointer-events-none">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-light-accent dark:from-dark-accent via-transparent to-transparent"></div>
        
        <div class="relative z-10 flex flex-col gap-10">
            <div class="space-y-4">
                <p class="text-[10px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em]">Navigation</p>
                <div class="grid grid-cols-1 gap-4">
                    <a href={import.meta.env.BASE_URL} class="flex items-center gap-4 p-6 bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-3xl group active:scale-95 transition-all">
                        <div class="p-3 bg-light-accent/5 dark:bg-dark-accent/5 rounded-2xl text-light-accent dark:text-dark-accent">
                            <Home size={24} />
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xl font-black">Home</span>
                            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">Return to dashboard</span>
                        </div>
                    </a>
                    <a href={`${import.meta.env.BASE_URL}courses`} class="flex items-center gap-4 p-6 bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-3xl group active:scale-95 transition-all">
                        <div class="p-3 bg-primary/10 rounded-2xl text-primary">
                            <Book size={24} />
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xl font-black">Courses</span>
                            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">Browse all courses</span>
                        </div>
                    </a>
                    <a href={`${import.meta.env.BASE_URL}careers`} class="flex items-center gap-4 p-6 bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-3xl group active:scale-95 transition-all">
                        <div class="p-3 bg-primary/10 rounded-2xl text-primary">
                            <Compass size={24} />
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xl font-black">Career Paths</span>
                            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">Follow role-based curricula</span>
                        </div>
                    </a>
                    <a href={`${import.meta.env.BASE_URL}about`} class="flex items-center gap-4 p-6 bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-3xl group active:scale-95 transition-all">
                        <div class="p-3 bg-primary/10 rounded-2xl text-primary">
                            <Users size={24} />
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xl font-black">About</span>
                            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">LibreUni's mission</span>
                        </div>
                    </a>
                </div>
            </div>

            <div class="space-y-4">
                <p class="text-[10px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em]">Search Knowledge</p>
                <Search client:load baseUrl={import.meta.env.BASE_URL} />
            </div>

            <div class="mt-auto py-12 text-center">
                <p class="text-[10px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em] opacity-40">© 2026 LIBREUNI PROJECT</p>
            </div>
        </div>
    </div>

    <!-- Mobile Sidebar Backdrop (for lessons) -->
    <div id="sidebar-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[45] hidden transition-opacity opacity-0"></div>

    <div class="flex min-h-screen relative pt-16">
      <slot />
    </div>

    <div id="diagram-overlay" class="diagram-overlay" aria-hidden="true">
      <button type="button" class="diagram-overlay-close" aria-label="Close diagram">Close</button>
      <div class="diagram-overlay-panel" role="dialog" aria-modal="true" aria-label="Expanded diagram">
        <div id="diagram-overlay-content" class="diagram-overlay-content"></div>
      </div>
    </div>

    <script is:inline>
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');

        menuToggle?.addEventListener('click', () => {
            const isOpen = !mobileMenu.classList.contains('translate-x-full');
            if (isOpen) {
                mobileMenu.classList.add('translate-x-full');
                mobileMenu.classList.add('pointer-events-none');
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
                document.body.style.overflow = '';
            } else {
                mobileMenu.classList.remove('translate-x-full');
                mobileMenu.classList.remove('pointer-events-none');
                menuIcon.classList.add('hidden');
                closeIcon.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }
        });

        // Close menu on link clicks
        mobileMenu?.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('translate-x-full');
                mobileMenu.classList.add('pointer-events-none');
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
                document.body.style.overflow = '';
            });
        });

        const diagramOverlay = document.getElementById('diagram-overlay');
        const diagramOverlayContent = document.getElementById('diagram-overlay-content');
        const diagramOverlayClose = diagramOverlay?.querySelector('.diagram-overlay-close');
        let diagramPreviousFocus = null;

        function closeDiagramOverlay() {
            if (!diagramOverlay || !diagramOverlayContent) return;
            diagramOverlay.classList.remove('is-open');
            diagramOverlay.setAttribute('aria-hidden', 'true');
            diagramOverlayContent.replaceChildren();
            document.body.style.overflow = '';
            if (diagramPreviousFocus && typeof diagramPreviousFocus.focus === 'function') {
                diagramPreviousFocus.focus();
            }
        }

        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            if (target.closest('.diagram-source')) return;

            const openButton = target.closest('.diagram-open-button');
            const frame = openButton?.closest('.diagram-frame') ?? target.closest('.diagram-frame');
            if (frame && !target.closest('a') && !target.closest('.diagram-overlay')) {
                const render = frame.querySelector('.diagram-render');
                if (!render || !diagramOverlay || !diagramOverlayContent) return;
                diagramPreviousFocus = document.activeElement;
                diagramOverlayContent.replaceChildren(render.cloneNode(true));
                diagramOverlay.classList.add('is-open');
                diagramOverlay.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
                diagramOverlayClose?.focus();
            }
        });

        diagramOverlayClose?.addEventListener('click', closeDiagramOverlay);
        diagramOverlay?.addEventListener('click', (event) => {
            if (event.target === diagramOverlay) closeDiagramOverlay();
        });
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && diagramOverlay?.classList.contains('is-open')) {
                closeDiagramOverlay();
            }
        });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --accent: 0, 0, 0;
  }
  .dark {
    --accent: 255, 255, 255;
  }

  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    margin: 0;
  }

  .nav-fixed-header {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    height: 4rem !important;
    z-index: 99999 !important;
    width: 100% !important;
    isolation: isolate !important;
  }

  /* KATEX VISUAL FIXES */
  .katex-display {
    margin: 2rem 0 !important;
    overflow-x: auto;
    overflow-y: hidden;
    width: 100%;
  }

  .katex {
    font-size: 1.1em !important;
    text-indent: 0 !important;
  }

  .dark .katex {
    color: #ededed !important;
  }

  /* UNIFIED CODE BLOCK SYSTEM (START FROM ZERO) */
  .astro-code {
    @apply rounded-[2.5rem] p-10 my-8 shadow-2xl border transition-all duration-300 !important;
    font-size: 15.2px !important;
    line-height: 25.84px !important;
  }

  /* Light Theme (GitHub Light) */
  html:not(.dark) .astro-code {
    background-color: #ffffff !important;
    border-color: #e5e7eb !important;
  }

  /* Dark Theme (One Dark Pro) */
  html.dark .astro-code {
    background-color: #0f0f0f !important;
    border-color: #1a1a1a !important;
  }

  /* Syntax Classes for Interactive Highlighting (Refined Academic Palette) */
  /* These will be used by our custom components to ensure visual parity */
  
  /* DEFAULT TEXT - High Contrast */
  .hl-default { @apply text-light-text dark:text-dark-text; }
  /* KEYWORDS - Sophisticated Rose/Pink */
  .hl-keyword { @apply font-bold text-[#BE123C] dark:text-[#FB7185]; }
  /* TYPES - Deep Teal/Cyan */
  .hl-type { @apply font-bold text-[#0369A1] dark:text-[#38BDF8]; }
  /* FUNCTIONS - Academic Blue */
  .hl-function { @apply text-[#1D4ED8] dark:text-[#60A5FA]; }
  /* STRINGS - Forest Green/Emerald */
  .hl-string { @apply text-[#15803D] dark:text-[#34D399]; }
  /* COMMENTS - Neutral Gray */
  .hl-comment { @apply italic text-[#475569] dark:text-[#94A3B8]; }
  /* OPERATORS - Dark Neutral */
  .hl-operator { @apply text-[#1E293B] dark:text-[#E2E8F0]; }
  /* DIRECTIVES - Royal Purple */
  .hl-directive { @apply text-[#6D28D9] dark:text-[#A78BFA]; }
  /* NUMBERS - Burnt Orange */
  .hl-number { @apply text-[#B45309] dark:text-[#FBBF24]; }
  /* BRACKETS - Muted Slate */
  .hl-bracket { @apply text-slate-500 dark:text-slate-400; }

  /* Code Container Base */
  .code-container-base {
    @apply font-mono rounded-3xl border transition-all;
    @apply bg-white dark:bg-[#0f172a] border-light-border dark:border-slate-800;
    @apply text-light-text dark:text-dark-text;
    padding: 40px; /* p-10 */
    font-size: 15.2px;
    line-height: 25.84px;
  }

  .diagram-frame {
    position: relative;
    overflow: hidden;
    cursor: zoom-in;
  }

  .diagram-render {
    overflow: hidden;
  }

  .diagram-render > svg,
  .diagram-render img {
    display: block;
    width: auto !important;
    height: auto !important;
    max-width: 100% !important;
    max-height: min(64vh, 720px);
    object-fit: contain;
  }

  .diagram-open-button {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--light-border);
    background: rgba(255, 255, 255, 0.92);
    color: var(--light-text);
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0;
    transform: translateY(-0.25rem);
    transition: opacity 0.2s, transform 0.2s, background-color 0.2s;
    cursor: zoom-in;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.12);
  }

  .diagram-toolbar {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 3;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .diagram-toolbar .diagram-open-button {
    position: static;
  }

  .diagram-source {
    position: relative;
  }

  .diagram-source-summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--light-border);
    background: rgba(255, 255, 255, 0.92);
    color: var(--light-text);
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    list-style: none;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.12);
  }

  .diagram-source-summary::-webkit-details-marker {
    display: none;
  }

  .dark .diagram-source-summary {
    border-color: var(--dark-border);
    background: rgba(15, 23, 42, 0.92);
    color: var(--dark-text);
  }

  .diagram-source-code {
    position: absolute;
    top: calc(100% + 0.625rem);
    right: 0;
    width: min(42rem, calc(100vw - 3rem));
    max-height: min(28rem, 60vh);
    overflow: auto;
    margin: 0 !important;
    padding: 1rem !important;
    border-radius: 1rem !important;
    border: 1px solid var(--light-border);
    background: rgba(255, 255, 255, 0.98) !important;
    color: var(--light-text) !important;
    font-size: 0.78rem !important;
    line-height: 1.55 !important;
    text-align: left;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.2);
    cursor: auto;
  }

  .dark .diagram-source-code {
    border-color: var(--dark-border);
    background: rgba(15, 23, 42, 0.98) !important;
    color: var(--dark-text) !important;
  }

  .diagram-source-title {
    align-self: flex-start;
    margin-top: 0.75rem;
    font-size: 0.62rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--light-muted);
  }

  .dark .diagram-source-title {
    color: var(--dark-muted);
  }

  .dark .diagram-open-button {
    border-color: var(--dark-border);
    background: rgba(15, 23, 42, 0.92);
    color: var(--dark-text);
  }

  .diagram-frame:hover .diagram-open-button,
  .diagram-open-button:focus-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .diagram-overlay {
    position: fixed;
    inset: 0;
    z-index: 100000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 5rem 1rem 1rem;
    background: rgba(2, 6, 23, 0.72);
    backdrop-filter: blur(14px);
  }

  .diagram-overlay.is-open {
    display: flex;
  }

  .diagram-overlay-panel {
    max-width: 96vw;
    max-height: 84vh;
    overflow: auto;
    border-radius: 1.25rem;
    border: 1px solid rgba(226, 232, 240, 0.35);
    background: #ffffff;
    padding: 1.25rem;
    box-shadow: 0 30px 100px rgba(0, 0, 0, 0.35);
  }

  .dark .diagram-overlay-panel {
    background: #0f172a;
    border-color: rgba(148, 163, 184, 0.24);
  }

  .diagram-overlay-content .diagram-render {
    max-width: none;
    overflow: visible;
  }

  .diagram-overlay-content .diagram-render > svg,
  .diagram-overlay-content .diagram-render img {
    width: min(1400px, calc(96vw - 3rem)) !important;
    height: auto !important;
    max-width: calc(96vw - 3rem) !important;
    max-height: none;
  }

  .diagram-overlay-close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 1;
    min-height: 2.5rem;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(15, 23, 42, 0.92);
    color: white;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
  }

  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    @apply bg-transparent;
  }
  ::-webkit-scrollbar-thumb {
    @apply bg-slate-300 dark:bg-slate-700 rounded-full border-4 border-transparent bg-clip-padding;
  }
  ::-webkit-scrollbar-thumb:hover {
    @apply bg-slate-400 dark:bg-slate-600;
  }
</style>
