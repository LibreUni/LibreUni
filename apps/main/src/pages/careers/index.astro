---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import {
    ArrowRight,
    BookOpen,
    Brain,
    Calculator,
    Code2,
    Compass,
    Cpu,
    FlaskConical,
    GraduationCap,
    LayoutIcon,
    Shapes,
    Users
} from 'lucide-react';

const careers = await getCollection('careers');

const iconMap: Record<string, any> = {
    calculator: Calculator,
    layout: LayoutIcon,
    code: Code2,
    brain: Brain,
    cpu: Cpu,
    science: FlaskConical,
    elements: Shapes,
    book: BookOpen,
    users: Users,
    graduation: GraduationCap,
    compass: Compass
};
---

<Layout title="Career Paths - LibreUni">
  <main class="flex-1 bg-light-bg dark:bg-dark-bg">
    <section class="border-b border-light-border bg-white px-6 py-16 dark:border-dark-border dark:bg-dark-bg md:px-8 md:py-24">
        <div class="mx-auto max-w-7xl">
            <p class="mb-4 text-xs font-black uppercase tracking-[0.25em] text-primary">Career Paths</p>
            <div class="grid gap-8 md:grid-cols-[1fr_24rem] md:items-end">
                <div>
                    <h1 class="text-5xl font-black uppercase leading-none tracking-tight text-light-text dark:text-dark-text md:text-7xl">Role-Based Study</h1>
                    <p class="mt-6 max-w-3xl text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                        Curricula organized around professional outcomes, combining internal LibreUni courses with carefully chosen external references where the path needs them.
                    </p>
                </div>
                <div class="rounded-2xl border border-light-border bg-light-surface p-6 dark:border-dark-border dark:bg-dark-surface">
                    <p class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text">{careers.length}</p>
                    <p class="mt-1 text-xs font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Paths available</p>
                </div>
            </div>
        </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-16 md:px-8">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {careers.map((career) => {
                const Icon = iconMap[career.data.icon] || GraduationCap;
                const internalCourses = career.data.steps.flatMap(step => step.courses).filter(course => course.type === 'internal').length;
                const externalResources = career.data.steps.flatMap(step => step.courses).filter(course => course.type === 'external').length;

                return (
                    <a
                        href={`${import.meta.env.BASE_URL}careers/${career.id}`}
                        class="group flex min-h-80 flex-col rounded-2xl border border-light-border bg-white p-8 transition-all hover:-translate-y-1 hover:border-primary/50 hover:shadow-2xl hover:shadow-slate-200/70 dark:border-dark-border dark:bg-dark-surface dark:hover:shadow-black/30"
                    >
                        <div class="mb-10 flex items-start justify-between">
                            <div class={`rounded-2xl bg-gradient-to-br ${career.data.color} p-4 text-white shadow-xl shadow-primary/10 transition-transform group-hover:scale-105`}>
                                <Icon size={28} strokeWidth={2.5} />
                            </div>
                            <div class="career-progress hidden flex-col items-end gap-1" data-career-id={career.id}>
                                <span class="text-[10px] font-black uppercase tracking-widest text-primary">Progress</span>
                                <span class="progress-text text-xl font-black tabular-nums text-light-text dark:text-dark-text">0%</span>
                            </div>
                        </div>

                        <div class="mt-auto">
                            <h2 class="text-2xl font-black tracking-tight text-light-text transition-colors group-hover:text-primary dark:text-dark-text">{career.data.title}</h2>
                            <p class="mt-3 line-clamp-3 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">{career.data.description}</p>

                            <div class="mt-8 grid grid-cols-3 gap-3 border-t border-light-border pt-6 dark:border-dark-border">
                                <div>
                                    <p class="text-lg font-black text-light-text dark:text-dark-text">{career.data.steps.length}</p>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Phases</p>
                                </div>
                                <div>
                                    <p class="text-lg font-black text-light-text dark:text-dark-text">{internalCourses}</p>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Courses</p>
                                </div>
                                <div>
                                    <p class="text-lg font-black text-light-text dark:text-dark-text">{externalResources}</p>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Refs</p>
                                </div>
                            </div>

                            <div class="mt-8 flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary">
                                View Path
                                <ArrowRight size={15} className="transition-transform group-hover:translate-x-1" />
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>
    </section>
  </main>
</Layout>

<script is:inline>
    function updateCareerProgress() {
        const careerBadges = document.querySelectorAll('.career-progress');
        careerBadges.forEach(badge => {
            const id = badge.getAttribute('data-career-id');
            const progress = localStorage.getItem(`career-progress-${id}`);
            if (progress !== null) {
                badge.classList.remove('hidden');
                badge.classList.add('flex');
                badge.querySelector('.progress-text').innerText = `${progress}%`;
            }
        });
    }

    updateCareerProgress();
    window.addEventListener('storage', updateCareerProgress);
</script>
