---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  const lessons = await getCollection('lessons');
  
  return courses.map(course => {
    const courseLessons = lessons
      .filter(l => l.data.course === course.id)
      .sort((a, b) => a.data.order - b.data.order);
      
    return {
      params: { courseId: course.id },
      props: { lessons: courseLessons }
    };
  });
}

const { courseId } = Astro.params;
const { lessons } = Astro.props;

const firstLessonSlug = lessons.length > 0 ? lessons[0].slug : '';
const validSlugs = lessons.map(l => l.slug);
---

<Layout title="Redirecting...">
    <div class="min-h-screen flex items-center justify-center bg-light-bg dark:bg-dark-bg">
        <div class="text-center">
            <div class="w-16 h-16 border-4 border-primary border-t-transparent animate-spin rounded-full mx-auto mb-6"></div>
            <p class="text-light-muted dark:text-dark-muted font-black uppercase tracking-[0.2em] text-xs">Resuming Track...</p>
        </div>
    </div>
</Layout>

<script is:inline define:vars={{ courseId, firstLessonSlug, validSlugs, baseUrl: import.meta.env.BASE_URL }}>
    // Client-side redirect to support localStorage-based progress tracking
    const lastVisited = localStorage.getItem(`last-visited-${courseId}`);
    
    // Safety check: ensure the last visited slug actually belongs to this course and still exists
    const isValid = lastVisited && validSlugs.includes(lastVisited);
    
    if (isValid) {
        window.location.href = `${baseUrl}lessons/${lastVisited}.html`;
    } else if (firstLessonSlug) {
        window.location.href = `${baseUrl}lessons/${firstLessonSlug}.html`;
    } else {
        window.location.href = `${baseUrl}index.html`;
    }
</script>
