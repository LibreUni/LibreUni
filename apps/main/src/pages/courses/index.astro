---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import courseQuality from '../../data/course-quality.json';
import {
    ArrowRight,
    Binary,
    BookOpen,
    Brain,
    Calculator,
    Code2,
    Compass,
    Cpu,
    FlaskConical,
    GraduationCap,
    LayoutIcon,
    Shapes,
    Users
} from '../../components/Icons';

const courses = await getCollection('courses');
const lessons = await getCollection('lessons');

const iconMap: Record<string, any> = {
    calculator: Calculator,
    layout: LayoutIcon,
    code: Code2,
    brain: Brain,
    cpu: Cpu,
    science: FlaskConical,
    elements: Shapes,
    binary: Binary,
    book: BookOpen,
    users: Users,
    graduation: GraduationCap,
    compass: Compass
};

const categoryLabels: Record<string, string> = {
    all: 'All categories',
    math: 'Mathematics',
    cs: 'Computer Science',
    ai: 'AI & ML',
    dev: 'Development',
    phil: 'Philosophy',
    mgmt: 'Management',
    other: 'Misc'
};

const getCategory = (courseId: string) => {
    if (courseId.startsWith('math')) return 'math';
    if (['c', 'cpp', 'operating-systems', 'software-engineering', 'software-architecture', 'programming-languages'].includes(courseId)) return 'cs';
    if (['machine-learning'].includes(courseId)) return 'ai';
    if (['philosophy', 'philosophy-science'].includes(courseId)) return 'phil';
    if (['devops', 'git', 'uml', 'python', 'javascript', 'libreuni', 'power-user'].includes(courseId)) return 'dev';
    if (['team-dynamics'].includes(courseId)) return 'mgmt';
    return 'other';
};

const defaultQuality = {
    overall: { level: 0, label: 'Unmeasured', score: 0 },
    metrics: {
        sources: { level: 0, label: 'Unmeasured', coverage: 0, referenceHeadingCoverage: 0, linkedSourceCoverage: 0 },
        content: { level: 0, label: 'Unmeasured', averageWords: 0, descriptionCoverage: 0, exampleCoverage: 0, exerciseCoverage: 0 },
        practice: { level: 0, label: 'Unmeasured', interactiveCoverage: 0, averageInteractiveComponents: 0 },
        review: { level: 0, label: 'Not reviewed', manual: true }
    }
};

const qualityByCourse = courseQuality as Record<string, typeof defaultQuality>;

const statusStyles = [
    {
        dot: 'bg-rose-500',
        ring: 'ring-rose-500/20',
        text: 'text-rose-600 dark:text-rose-400',
        bg: 'bg-rose-50 dark:bg-rose-500/10',
        border: 'border-rose-200 dark:border-rose-500/20'
    },
    {
        dot: 'bg-amber-400',
        ring: 'ring-amber-400/20',
        text: 'text-amber-700 dark:text-amber-300',
        bg: 'bg-amber-50 dark:bg-amber-400/10',
        border: 'border-amber-200 dark:border-amber-400/20'
    },
    {
        dot: 'bg-emerald-500',
        ring: 'ring-emerald-500/20',
        text: 'text-emerald-700 dark:text-emerald-300',
        bg: 'bg-emerald-50 dark:bg-emerald-500/10',
        border: 'border-emerald-200 dark:border-emerald-500/20'
    }
];

const metricFill = (level: number) => `${Math.max(0, Math.min(3, level)) / 3 * 100}%`;
const percent = (value: number) => `${Math.round(value * 100)}%`;
---

<Layout title="All Courses - LibreUni">
  <main class="flex-1 bg-light-bg dark:bg-dark-bg">
    <section class="border-b border-light-border bg-white px-6 py-16 dark:border-dark-border dark:bg-dark-bg md:px-8 md:py-24">
        <div class="mx-auto max-w-7xl">
            <p class="mb-4 text-xs font-black uppercase tracking-[0.25em] text-primary">All Courses</p>
            <div class="grid gap-8 md:grid-cols-[1fr_24rem] md:items-end">
                <div>
                    <h1 class="text-5xl font-black uppercase leading-none tracking-tight text-light-text dark:text-dark-text md:text-7xl">Course Catalog</h1>
                    <p class="mt-6 max-w-3xl text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                        Complete university-level tracks for mathematics, computing, engineering practice, philosophy, and professional systems work.
                    </p>
                </div>
                <div class="relative overflow-hidden rounded-2xl border border-light-border bg-light-surface p-6 dark:border-dark-border dark:bg-dark-surface">
                    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-rose-500/10"></div>
                    <div class="relative">
                        <p class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text">{courses.length}</p>
                        <p class="mt-1 text-xs font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Courses available</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-12 md:px-8">
        <div class="sticky top-16 z-30 mb-10 rounded-2xl border border-light-border bg-white/95 p-4 shadow-xl shadow-slate-200/60 backdrop-blur dark:border-dark-border dark:bg-dark-surface/95 dark:shadow-black/20">
            <div class="grid gap-3 lg:grid-cols-[1fr_12rem_14rem_7rem] lg:items-center">
                <label class="relative block">
                    <span class="sr-only">Search courses</span>
                    <svg class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-light-muted dark:text-dark-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input id="course-search" type="text" placeholder="Search courses" class="input-field pl-11 dark:text-white" />
                </label>

                <label class="block">
                    <span class="sr-only">Filter category</span>
                    <select id="category-filter" class="input-field cursor-pointer dark:text-white">
                        {Object.entries(categoryLabels).map(([value, label]) => (
                            <option value={value}>{label}</option>
                        ))}
                    </select>
                </label>

                <label class="block">
                    <span class="sr-only">Sort courses</span>
                    <select id="course-sort" class="input-field cursor-pointer dark:text-white">
                        <option value="title-asc">A to Z</option>
                        <option value="title-desc">Z to A</option>
                        <option value="modules-desc">Most modules</option>
                        <option value="modules-asc">Fewest modules</option>
                        <option value="status-desc">Strongest status</option>
                        <option value="status-asc">Needs most work</option>
                        <option value="sources-desc">Best sourced</option>
                        <option value="content-desc">Most complete</option>
                    </select>
                </label>

                <div class="rounded-xl border border-light-border bg-light-surface px-4 py-3 text-center dark:border-dark-border dark:bg-dark-bg">
                    <span id="course-count" class="text-sm font-black text-light-text dark:text-dark-text">{courses.length}</span>
                    <span class="block text-[9px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Shown</span>
                </div>
            </div>
        </div>

        <div id="course-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {courses.map((course) => {
                const Icon = iconMap[course.data.icon] || BookOpen;
                const isCustomIcon = course.data.icon.includes('/') || course.data.icon.includes('.');
                const lessonCount = lessons.filter(lesson => lesson.data.course === course.id).length;
                const category = getCategory(course.id);
                const quality = qualityByCourse[course.id] ?? defaultQuality;
                const style = statusStyles[quality.overall.level] ?? statusStyles[0];

                return (
                    <article
                        class="course-card group relative flex min-h-72 flex-col overflow-visible rounded-2xl border border-light-border bg-white transition-all hover:-translate-y-1 hover:border-primary/50 hover:shadow-2xl hover:shadow-slate-200/70 dark:border-dark-border dark:bg-dark-surface dark:hover:shadow-black/30"
                        data-category={category}
                        data-title={course.data.title.toLowerCase()}
                        data-modules={lessonCount}
                        data-status={quality.overall.level}
                        data-sources={quality.metrics.sources.level}
                        data-content={quality.metrics.content.level}
                    >
                        <div class="pointer-events-none absolute inset-0 rounded-2xl bg-gradient-to-br from-primary/10 via-transparent to-rose-500/10 opacity-70 transition-opacity group-hover:opacity-100"></div>
                        <div class={`pointer-events-none absolute left-0 right-0 top-0 h-1.5 rounded-t-[calc(1rem-1px)] ${course.data.color}`}></div>

                        <a href={`${import.meta.env.BASE_URL}courses/${course.id}`} class="relative flex flex-1 flex-col p-8 focus:outline-none focus-visible:ring-4 focus-visible:ring-primary/20 rounded-2xl" aria-label={`Open ${course.data.title}`}>
                            <div class="mb-10 flex items-start justify-between gap-4">
                                <div class="rounded-2xl border border-light-border bg-white/80 p-4 text-light-text shadow-sm transition-all group-hover:bg-primary group-hover:text-white dark:border-dark-border dark:bg-dark-bg/80 dark:text-dark-text">
                                    {isCustomIcon ? (
                                        <img src={course.data.icon} alt={course.data.title} class="h-7 w-7 object-contain" />
                                    ) : (
                                        <Icon size={28} strokeWidth={2.5} />
                                    )}
                                </div>
                            </div>

                            <div class="mt-auto">
                                <div class="mb-4 flex items-center gap-2">
                                    <span class="rounded-full bg-primary/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-primary">{lessonCount} Modules</span>
                                    <span class="rounded-full bg-light-surface px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-light-muted dark:bg-dark-bg dark:text-dark-muted">{categoryLabels[category]}</span>
                                </div>
                                <h2 class="text-2xl font-black tracking-tight text-light-text transition-colors group-hover:text-primary dark:text-dark-text">{course.data.title}</h2>
                                <p class="mt-3 line-clamp-3 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">{course.data.description}</p>

                                <div class="mt-8 flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary">
                                    Begin Track
                                    <ArrowRight size={15} className="transition-transform group-hover:translate-x-1" />
                                </div>
                            </div>
                        </a>

                        <div class="quality-wrapper absolute right-8 top-8 z-20">
                            <button type="button" class={`quality-trigger inline-flex items-center gap-2 rounded-full border px-3 py-2 text-[10px] font-black uppercase tracking-widest outline-none ring-4 ${style.bg} ${style.border} ${style.text} ${style.ring}`} aria-label={`Course status: ${quality.overall.label}`}>
                                <span class={`h-2.5 w-2.5 rounded-full ${style.dot}`}></span>
                                {quality.overall.label}
                            </button>

                            <div class="quality-popover pointer-events-none absolute right-0 top-full mt-3 w-80 rounded-2xl border border-light-border bg-white p-5 text-left opacity-0 shadow-2xl shadow-slate-300/70 transition-all duration-200 dark:border-dark-border dark:bg-dark-bg dark:shadow-black/40">
                                <div class="mb-4 flex items-center justify-between gap-4">
                                    <p class="text-sm font-black text-light-text dark:text-dark-text">Course status</p>
                                    <p class={`text-[10px] font-black uppercase tracking-widest ${style.text}`}>{quality.overall.label}</p>
                                </div>

                                <div class="space-y-4">
                                    <div>
                                        <div class="mb-1 flex items-center justify-between gap-3">
                                            <span class="text-[10px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Sources</span>
                                            <span class="text-xs font-bold text-light-text dark:text-dark-text">{quality.metrics.sources.label}</span>
                                        </div>
                                        <div class="h-2 rounded-full bg-light-surface dark:bg-dark-surface">
                                            <div class="h-2 rounded-full bg-primary" style={`width: ${metricFill(quality.metrics.sources.level)}`}></div>
                                        </div>
                                        <p class="mt-1 text-xs font-medium text-light-muted dark:text-dark-muted">{percent(quality.metrics.sources.coverage)} of lessons have source tracking.</p>
                                    </div>

                                    <div>
                                        <div class="mb-1 flex items-center justify-between gap-3">
                                            <span class="text-[10px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Content</span>
                                            <span class="text-xs font-bold text-light-text dark:text-dark-text">{quality.metrics.content.label}</span>
                                        </div>
                                        <div class="h-2 rounded-full bg-light-surface dark:bg-dark-surface">
                                            <div class="h-2 rounded-full bg-primary" style={`width: ${metricFill(quality.metrics.content.level)}`}></div>
                                        </div>
                                        <p class="mt-1 text-xs font-medium text-light-muted dark:text-dark-muted">Average lesson length: {quality.metrics.content.averageWords} words.</p>
                                    </div>

                                    <div>
                                        <div class="mb-1 flex items-center justify-between gap-3">
                                            <span class="text-[10px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Practice</span>
                                            <span class="text-xs font-bold text-light-text dark:text-dark-text">{quality.metrics.practice.label}</span>
                                        </div>
                                        <div class="h-2 rounded-full bg-light-surface dark:bg-dark-surface">
                                            <div class="h-2 rounded-full bg-primary" style={`width: ${metricFill(quality.metrics.practice.level)}`}></div>
                                        </div>
                                        <p class="mt-1 text-xs font-medium text-light-muted dark:text-dark-muted">{percent(quality.metrics.practice.interactiveCoverage)} of lessons include interactive components.</p>
                                    </div>

                                    <div class="rounded-xl border border-light-border bg-light-surface p-3 dark:border-dark-border dark:bg-dark-surface">
                                        <p class="text-[10px] font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Review</p>
                                        <p class="mt-1 text-xs font-bold text-light-text dark:text-dark-text">{quality.metrics.review.label}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                );
            })}
        </div>
    </section>
  </main>
</Layout>

<script is:inline>
    const cards = Array.from(document.querySelectorAll('.course-card'));
    const grid = document.getElementById('course-grid');
    const searchInput = document.getElementById('course-search');
    const categoryFilter = document.getElementById('category-filter');
    const sortSelect = document.getElementById('course-sort');
    const countLabel = document.getElementById('course-count');

    const sorters = {
        'title-asc': (a, b) => a.dataset.title.localeCompare(b.dataset.title),
        'title-desc': (a, b) => b.dataset.title.localeCompare(a.dataset.title),
        'modules-desc': (a, b) => Number(b.dataset.modules) - Number(a.dataset.modules),
        'modules-asc': (a, b) => Number(a.dataset.modules) - Number(b.dataset.modules),
        'status-desc': (a, b) => Number(b.dataset.status) - Number(a.dataset.status),
        'status-asc': (a, b) => Number(a.dataset.status) - Number(b.dataset.status),
        'sources-desc': (a, b) => Number(b.dataset.sources) - Number(a.dataset.sources),
        'content-desc': (a, b) => Number(b.dataset.content) - Number(a.dataset.content),
    };

    function updateCourses() {
        const query = searchInput?.value.toLowerCase().trim() ?? '';
        const category = categoryFilter?.value ?? 'all';
        const sorter = sorters[sortSelect?.value] ?? sorters['title-asc'];
        let visibleCount = 0;

        const sortedCards = [...cards].sort(sorter);
        sortedCards.forEach(card => grid?.appendChild(card));

        sortedCards.forEach(card => {
            const matchesCategory = category === 'all' || card.dataset.category === category;
            const matchesSearch = !query || card.textContent.toLowerCase().includes(query);
            const isVisible = matchesCategory && matchesSearch;
            card.classList.toggle('hidden', !isVisible);
            if (isVisible) visibleCount += 1;
        });

        if (countLabel) countLabel.textContent = String(visibleCount);
    }

    searchInput?.addEventListener('input', updateCourses);
    categoryFilter?.addEventListener('change', updateCourses);
    sortSelect?.addEventListener('change', updateCourses);
    updateCourses();
</script>

<style>
    .quality-wrapper:hover .quality-popover,
    .quality-wrapper:focus-within .quality-popover {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .quality-popover {
        transform: translateY(-0.25rem);
    }
</style>
