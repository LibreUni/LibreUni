                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div id="draft-warnings-list" class="mt-4 space-y-3 opacity-60 hover:opacity-100 transition-opacity"></div>
          </details>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
const dashboard = document.getElementById('ml-dashboard');
if (dashboard && dashboard.dataset.courses) {
  const COURSES = JSON.parse(atob(dashboard.dataset.courses));

  if (COURSES && COURSES.length > 0) {
    const FEATURES = ['characters', 'lessons', 'modules', 'charactersPerLesson', 'charactersPerModule', 'lessonsPerModule', 'averageWords', 'qualityScore'];
    const LABELS = {
      pca1: 'PCA 1', pca2: 'PCA 2', characters: 'Total characters', lessons: 'Lessons', modules: 'Modules',
      charactersPerLesson: 'Chars / lesson', charactersPerModule: 'Chars / module', lessonsPerModule: 'Lessons / module',
      averageWords: 'Avg words', qualityScore: 'Quality score',
    };

    const mean = (values) => values.length ? values.reduce((s, v) => s + v, 0) / values.length : 0;
    const distance = (a, b) => Math.hypot(...a.map((v, i) => v - b[i]));
    const multiply = (mat, vec) => mat.map((row) => row.reduce((s, v, i) => s + v * vec[i], 0));
    const normalize = (vec) => { const len = Math.hypot(...vec) || 1; return vec.map((v) => v / len); };
    const powerIteration = (mat, seed) => {
      let vec = normalize(seed);
      for (let i = 0; i < 80; i++) vec = normalize(multiply(mat, vec));
      const eigenvalue = vec.reduce((s, v, i) => s + v * multiply(mat, vec)[i], 0);
      return { eigenvalue, vector: vec };
    };

    const raw = COURSES.map((c) => FEATURES.map((k) => Number(c[k])));
    const standardized = raw.map((row) => row.map((v, col) => {
      const values = raw.map((r) => r[col]);
      const avg = mean(values);
      const dev = Math.sqrt(mean(values.map((x) => (x - avg) ** 2))) || 1;
      return (v - avg) / dev;
    }));
    const covariance = FEATURES.map((_, r) => FEATURES.map((__, c) => mean(standardized.map((row) => row[r] * row[c]))));

    const components = [];
    let current = covariance.map((r) => [...r]);
    for (let i = 0; i < 8; i++) {
      const seed = FEATURES.map((_, idx) => ((idx + i) % 2 ? 1 : -1) / (idx + 1 + i * 0.1));
      const pc = powerIteration(current, seed);
      components.push(pc);
      current = current.map((row, r) => row.map((v, c) => v - pc.eigenvalue * pc.vector[r] * pc.vector[c]));
    }
    const totalVar = components.reduce((s, c) => s + c.eigenvalue, 0);
    const varRatios = components.map((c) => totalVar > 0 ? c.eigenvalue / totalVar : 0);
    const cumulative = varRatios.reduce((acc, v) => { acc.push((acc.at(-1) || 0) + v); return acc; }, []);

    COURSES.forEach((c, i) => {
      c.pca1 = standardized[i].reduce((s, v, col) => s + v * components[0].vector[col], 0);
      c.pca2 = standardized[i].reduce((s, v, col) => s + v * components[1].vector[col], 0);
    });

    const k = Math.min(3, COURSES.length);
    let centers = [standardized[0], standardized[Math.floor(standardized.length / 2)], standardized.at(-1)].slice(0, k).map((c) => [...c]);
    let assignments = [];
    for (let iter = 0; iter < 40; iter++) {
      assignments = standardized.map((row) => centers.reduce((best, center, idx) => distance(row, center) < distance(row, centers[best]) ? idx : best, 0));
      centers = centers.map((center, idx) => {
        const members = standardized.filter((_, ri) => assignments[ri] === idx);
        return members.length ? center.map((_, col) => mean(members.map((m) => m[col]))) : center;
      });
    }
    const clusterDist = standardized.map((row, i) => distance(row, centers[assignments[i]]));
    const outlierCut = Math.max(1, Math.ceil(COURSES.length * 0.1));
    const outlierSet = new Set(clusterDist.map((d, i) => ({ d, i })).sort((a, b) => b.d - a.d).slice(0, outlierCut).map((x) => x.i));
    COURSES.forEach((c, i) => { c.cluster = assignments[i]; c.outlier = outlierSet.has(i); c.outlierScore = clusterDist[i]; });

    function renderScree() {
      const svg = document.getElementById('scree-plot');
      if (!svg) return;
      svg.classList.remove('hidden');
      const W = 800, H = 260, L = 50, R = 20, T = 20, B = 45;
      const plotW = W - L - R, plotH = H - T - B;
      const yMax = 1.0;
      const barW = Math.min(50, plotW / 8 * 0.55);
      const gap = (plotW - barW * 8) / 9;
      let html = `<rect x="0" y="0" width="${W}" height="${H}" fill="none"/>`;
      html += `<line x1="${L}" y1="${T}" x2="${L}" y2="${T + plotH}" stroke="currentColor" opacity="0.3"/>`;
      html += `<line x1="${L}" y1="${T + plotH}" x2="${L + plotW}" y2="${T + plotH}" stroke="currentColor" opacity="0.3"/>`;
      for (let pct = 0; pct <= 100; pct += 25) {
        const y = T + plotH - (pct / 100) * plotH;
        html += `<text x="${L - 6}" y="${y + 4}" text-anchor="end" font-size="10" fill="currentColor" opacity="0.5">${pct}%</text>`;
        html += `<line x1="${L}" y1="${y}" x2="${L + plotW}" y2="${y}" stroke="currentColor" opacity="0.08" stroke-dasharray="3,3"/>`;
      }
      const pathData = [];
      cumulative.forEach((cum, i) => {
        const x = L + gap + i * (barW + gap);
        const barH = cum * plotH;
        const y = T + plotH - barH;
        html += `<rect x="${x}" y="${y}" width="${barW}" height="${barH}" fill="currentColor" opacity="${0.1 + 0.3 * cum}" rx="2"/>`;
        html += `<text x="${x + barW / 2}" y="${T + plotH + 16}" text-anchor="middle" font-size="10" fill="currentColor" opacity="0.6">PC${i + 1}</text>`;
        pathData.push({ x: x + barW / 2, y });
      });
      let cumPath = '';
      pathData.forEach((pt, i) => {
        cumPath += `${i === 0 ? 'M' : 'L'}${pt.x} ${pt.y} `;
      });
      if (pathData.length) {
        html += `<path d="${cumPath}" fill="none" stroke="currentColor" stroke-width="2" opacity="0.6"/>`;
        pathData.forEach((pt, i) => {
          html += `<circle cx="${pt.x}" cy="${pt.y}" r="3.5" fill="currentColor" opacity="0.8"/>`;
          html += `<text x="${pt.x}" y="${pt.y - 8}" text-anchor="middle" font-size="9" font-weight="bold" fill="currentColor" opacity="0.85">${(cumulative[i] * 100).toFixed(0)}%</text>`;
        });
      }
      svg.innerHTML = html;
      const pc2cum = cumulative[1] || 0;
      const screeSummaryEl = document.getElementById('scree-summary');
      if (screeSummaryEl) {
        screeSummaryEl.textContent =
          `PC1 explains ${(varRatios[0] * 100).toFixed(1)}%, cumulative PC1+PC2 explains ${(pc2cum * 100).toFixed(1)}% of total variance.`;
      }
    }

    function renderScatter(xKey, yKey) {
      const svg = document.getElementById('scatter-plot');
      if (!svg) return;
      svg.classList.remove('hidden');
      const tooltip = document.getElementById('chart-tooltip');
      const W = 800, H = 300, L = 56, R = 20, T = 16, B = 40;
      const plotW = W - L - R, plotH = H - T - B;
      const xVals = COURSES.map((c) => Number(c[xKey]));
      const yVals = COURSES.map((c) => Number(c[yKey]));
      const scale = (v, list, start, size, invert = false) => {
        if (list.length === 0) return start + size / 2;
        const mn = Math.min(...list), mx = Math.max(...list);
        const ratio = mx === mn ? 0.5 : (v - mn) / (mx - mn);
        return start + (invert ? 1 - ratio : ratio) * size;
      };
      let html = `<line x1="${L}" y1="${T}" x2="${L}" y2="${T + plotH}" stroke="currentColor" opacity="0.3"/>`;
      html += `<line x1="${L}" y1="${T + plotH}" x2="${L + plotW}" y2="${T + plotH}" stroke="currentColor" opacity="0.3"/>`;
      html += `<text x="${L + plotW / 2}" y="${H - 4}" text-anchor="middle" font-size="11" fill="currentColor" opacity="0.5">${LABELS[xKey]}</text>`;
      html += `<text x="${12}" y="${T + plotH / 2}" text-anchor="middle" font-size="11" fill="currentColor" opacity="0.5" transform="rotate(-90,12,${T + plotH / 2})">${LABELS[yKey]}</text>`;
      const clusterLabels = ['Cluster 1', 'Cluster 2', 'Cluster 3'];
      const clusterColors = ['#3b82f6', '#6366f1', '#a855f7'];
      let legendHtml = '';
      for (let i = 0; i < k; i++) {
        const lx = L + i * 70;
        legendHtml += `<circle cx="${lx}" cy="${T - 6}" r="4" fill="${clusterColors[i]}"/><text x="${lx + 8}" y="${T - 2}" font-size="9" fill="currentColor" opacity="0.6">${clusterLabels[i]}</text>`;
      }
      html += legendHtml;
      const dots = [];
      COURSES.forEach((c, i) => {
        const x = scale(xVals[i], xVals, L, plotW);
        const y = scale(yVals[i], yVals, T, plotH, true);
        dots.push({ x, y, i, c });
      });
      dots.forEach(({ x, y, i, c }) => {
        html += `<circle cx="${x}" cy="${y}" r="${c.outlier ? 7 : 5}" fill="${clusterColors[c.cluster]}" opacity="${c.outlier ? 1 : 0.6}" stroke="${c.outlier ? '#ef4444' : 'none'}" stroke-width="${c.outlier ? 2 : 0}" class="scatter-dot cursor-pointer" data-index="${i}"/>`;
      });
      svg.innerHTML = html;
      svg.querySelectorAll('.scatter-dot').forEach((dot) => {
        const i = Number(dot.dataset.index);
        const c = COURSES[i];
        const xv = Number(c[xKey]), yv = Number(c[yKey]);
        dot.addEventListener('mouseenter', () => {
          if (tooltip) {
            tooltip.textContent = `${c.title}: ${LABELS[xKey]} ${xv.toLocaleString()}, ${LABELS[yKey]} ${yv.toLocaleString()}. ${clusterLabels[c.cluster]}${c.outlier ? `, outlier score ${c.outlierScore.toFixed(2)}` : ''}.`;
          }
        });
        dot.addEventListener('mouseleave', () => { if (tooltip) tooltip.textContent = ''; });
      });
    }

    function generateWarnings() {
      const all = [];
      for (const c of COURSES) {
        const q = c.quality;
        const sources = q?.metrics?.sources;
        const content = q?.metrics?.content;
        const practice = q?.metrics?.practice;
        const review = q?.metrics?.review;
        const overall = q?.overall;
        const isDraft = c.status === 'draft';

        if (overall?.score != null && overall.score < 1) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'high',
            message: `Quality score is very low (${overall.score.toFixed(2)}/3). Needs improvement across all dimensions.`,
            fix: "Add source references, interactive components (quizzes/exercises), expand word count, or organize lessons into modules to improve overall metrics."
          });
        }
        if (sources?.coverage === 0) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'high',
            message: 'No lessons have source citations. Add references to every lesson.',
            fix: "Add a '## References' section at the end of each lesson MDX file and list the cited sources."
          });
        }
        if (practice?.interactiveCoverage != null && practice.interactiveCoverage === 0) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'high',
            message: 'No interactive components (quizzes, code runners, exercises). Add practice elements.',
            fix: "Insert interactive React components such as <Quiz client:load>, <CodeExercise client:load>, <CodeRunner client:load>, or <CaseStudy client:load> into the lesson files."
          });
        }
        if (sources?.coverage != null && sources.coverage > 0 && sources.coverage < 0.75) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'medium',
            message: `Only ${Math.round(sources.coverage * 100)}% of lessons have source citations. Target 75% or higher.`,
            fix: "Identify lessons missing a '## References' section and add source citations to them."
          });
        }
        if (content?.descriptionCoverage != null && content.descriptionCoverage < 0.6) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'medium',
            message: `Only ${Math.round(content.descriptionCoverage * 100)}% of lessons have descriptions. Add descriptions for search and navigation.`,
            fix: "Add a 'description' field to the frontmatter header of the missing lesson files (e.g. description: \"Brief summary of this lesson.\")."
          });
        }
        if (content?.exampleCoverage != null && content.exampleCoverage < 0.5) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'medium',
            message: `Low example coverage (${Math.round(content.exampleCoverage * 100)}%). Add practical examples and case studies.`,
            fix: "Include the word 'example', 'case', 'demonstrate', or 'scenario' in lesson text, accompanied by concrete examples or scenarios."
          });
        }
        if (content?.exerciseCoverage != null && content.exerciseCoverage < 0.35) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'medium',
            message: `Low exercise coverage (${Math.round(content.exerciseCoverage * 100)}%). Add exercises for hands-on practice.`,
            fix: "Include the word 'exercise', 'practice', 'try', 'quiz', or 'lab' in lesson text, and add interactive exercises."
          });
        }
        if (c.lessons < 5) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'medium',
            message: `Only ${c.lessons} lessons. Consider expanding the course material.`,
            fix: "Add more lesson MDX files in apps/main/src/content/lessons/<course-id>/ to cover the topic comprehensively."
          });
        }
        if (c.averageWords > 0 && c.averageWords < 550) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'medium',
            message: `Lessons are very short (avg ${Math.round(c.averageWords)} words). Aim for 550+ words per lesson.`,
            fix: "Expand the explanations and detail in the current lessons to ensure they meet university-level depth."
          });
        }
        if (overall?.score != null && overall.score >= 1 && overall.score < 2) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'low',
            message: `Quality score (${overall.score.toFixed(2)}/3) is below the target of 2.`,
            fix: "Improve content details, add more interactive components, or secure external reviews to raise the score."
          });
        }
        if (review?.level === 0) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'low',
            message: 'Course has not been externally reviewed. Arrange a review to validate quality.',
            fix: "Request an external review from a subject matter expert. Once complete, update the reviewLevel in apps/main/src/data/course-quality-overrides.json."
          });
        }
        if (c.modules === 1 && c.lessons > 3) {
          all.push({
            course: c.title,
            isDraft,
            severity: 'low',
            message: 'Only one module with multiple lessons. Consider organizing into thematic modules.',
            fix: "Update the course manifest at apps/main/src/data/course-manifests/<course-id>.yml to organize lessons under multiple structured modules."
          });
        }
        if (c.outlier) {
          const avgDist = clusterDist.reduce((a, b) => a + b, 0) / clusterDist.length;
          const sev = c.outlierScore > avgDist * 2 ? 'high' : 'medium';
          all.push({
            course: c.title,
            isDraft,
            severity: sev,
            message: `Statistical outlier (distance ${c.outlierScore.toFixed(2)} from cluster center). Metrics deviate significantly from similar courses.`,
            fix: "Check if the course has an unusual number of lessons, extremely short/long word counts, or a disproportionate amount of practice vs prose relative to other courses."
          });
        }
      }
      return all;
    }

    function renderWarnings() {
      const container = document.getElementById('warnings-list');
      const empty = document.getElementById('warnings-empty');
      if (!container || !empty) return;
      const warnings = generateWarnings();
      
      const publicWarnings = warnings.filter((w) => !w.isDraft);
      const draftWarnings = warnings.filter((w) => w.isDraft);
      
      const groups = { high: [], medium: [], low: [] };
      for (const w of publicWarnings) groups[w.severity].push(w);
      
      const highCountEl = document.getElementById('high-count');
      const mediumCountEl = document.getElementById('medium-count');
      const lowCountEl = document.getElementById('low-count');
      if (highCountEl) highCountEl.textContent = groups.high.length;
      if (mediumCountEl) mediumCountEl.textContent = groups.medium.length;
      if (lowCountEl) lowCountEl.textContent = groups.low.length;

      const draftCountEl = document.getElementById('draft-count');
      if (draftCountEl) draftCountEl.textContent = draftWarnings.length;

      const draftContainer = document.getElementById('draft-warnings-container');
      if (draftContainer) {
        if (draftWarnings.length > 0) {
          draftContainer.classList.remove('hidden');
        } else {
          draftContainer.classList.add('hidden');
        }
      }

      const ACTIVE_CLASSES = ['border-primary', 'dark:border-primary', 'border-2', 'bg-primary', 'dark:bg-primary', 'text-white', 'dark:text-white'];
      const INACTIVE_CLASSES = ['border-light-border', 'dark:border-dark-border', 'border', 'bg-light-surface', 'dark:bg-dark-surface', 'text-light-text', 'dark:text-dark-text'];

      function render(filter) {
        const severities = filter === 'all' ? ['high', 'medium', 'low'] : [filter];
        const items = severities.flatMap((sev) => groups[sev].map((w) => ({ ...w, sev })));
        if (!items.length) {
          container.innerHTML = '';
          empty.classList.remove('hidden');
        } else {
          empty.classList.add('hidden');
          const borderMap = { high: 'border-2', medium: 'border', low: 'border border-dashed' };
          const iconMap = { high: '!', medium: '?', low: 'i' };
          container.innerHTML = items.map((w) => `
            <div class="warning-card rounded-xl ${borderMap[w.sev]} border-light-border bg-white p-4 dark:border-dark-border dark:bg-dark-bg">
              <div class="flex gap-3">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-light-text text-xs font-black text-light-bg dark:bg-dark-text dark:text-dark-bg">${iconMap[w.sev]}</span>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="text-sm font-black text-light-text dark:text-dark-text">${w.course}</span>
                    <span class="rounded border border-light-border bg-light-surface px-1.5 py-0.5 text-[10px] font-black uppercase tracking-wider text-light-muted dark:border-dark-border dark:bg-dark-surface dark:text-dark-muted">${w.severity}</span>
                  </div>
                  <p class="mt-1 text-sm leading-relaxed text-light-muted dark:text-dark-muted">${w.message}</p>
                  ${w.fix ? `
                  <div class="mt-3 rounded-lg bg-light-surface/50 p-2.5 dark:bg-dark-surface/50 border border-light-border dark:border-dark-border">
                    <p class="text-xs font-medium text-light-text dark:text-dark-text">
                      <span class="text-primary font-black uppercase tracking-wider text-[10px] mr-1">Suggested Fix:</span>${w.fix}
                    </p>
                  </div>
                  ` : ''}
                </div>
              </div>
            </div>
          `).join('');
        }

        // Render draft warnings in their own container list
        const draftList = document.getElementById('draft-warnings-list');
        if (draftList) {
          if (draftWarnings.length === 0) {
            draftList.innerHTML = '';
          } else {
            const borderMap = { high: 'border-2', medium: 'border', low: 'border border-dashed' };
            const iconMap = { high: '!', medium: '?', low: 'i' };
            draftList.innerHTML = draftWarnings.map((w) => `
              <div class="warning-card rounded-xl ${borderMap[w.severity]} border-light-border bg-white/60 p-4 dark:border-dark-border dark:bg-dark-bg/60">
                <div class="flex gap-3">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-light-muted text-xs font-black text-light-bg dark:bg-dark-muted dark:text-dark-bg">${iconMap[w.severity]}</span>
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="text-sm font-black text-light-muted dark:text-dark-muted">${w.course} (Draft)</span>
                      <span class="rounded border border-light-border bg-light-surface px-1.5 py-0.5 text-[10px] font-black uppercase tracking-wider text-light-muted dark:border-dark-border dark:bg-dark-surface dark:text-dark-muted">${w.severity}</span>
                    </div>
                    <p class="mt-1 text-sm leading-relaxed text-light-muted dark:text-dark-muted">${w.message}</p>
                    ${w.fix ? `
                    <div class="mt-3 rounded-lg bg-light-surface/30 p-2.5 dark:bg-dark-surface/30 border border-light-border/50 dark:border-dark-border/50">
                      <p class="text-xs font-medium text-light-muted dark:text-dark-muted">
                        <span class="text-light-muted dark:text-dark-muted font-black uppercase tracking-wider text-[10px] mr-1">Suggested Fix:</span>${w.fix}
                      </p>
                    </div>
                    ` : ''}
                  </div>
                </div>
              </div>
            `).join('');
          }
        }
      }

      document.querySelectorAll('[data-filter]').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('[data-filter]').forEach((b) => {
            b.classList.remove(...ACTIVE_CLASSES);
            b.classList.add(...INACTIVE_CLASSES);
          });
          btn.classList.remove(...INACTIVE_CLASSES);
          btn.classList.add(...ACTIVE_CLASSES);
          render(btn.dataset.filter);
        });
      });

      const allBtn = document.querySelector('[data-filter="all"]');
      if (allBtn) {
        allBtn.classList.remove(...INACTIVE_CLASSES);
        allBtn.classList.add(...ACTIVE_CLASSES);
      }
      render('all');
    }

    const summaryEl = document.getElementById('chart-summary');
    const pc2cum = cumulative[1] || 0;
    const clusterCount = new Set(assignments).size;
    if (summaryEl) {
      summaryEl.textContent =
        `PCA on 8 course metrics. ${(varRatios[0] * 100).toFixed(1)}% of variance captured by PC1, ${(pc2cum * 100).toFixed(1)}% by PC1+PC2. K-means found ${clusterCount} course clusters. ${outlierCut} courses flagged as outliers (top 10% by distance to cluster centroid). Contributors should review flagged outliers and high-severity warnings first.`;
    }

    renderScree();
    renderScatter('pca1', 'pca2');
    renderWarnings();

    document.querySelectorAll('[data-sort]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.sort;
        const tbody = document.getElementById('course-metrics');
        if (!tbody) return;
        const rows = [...tbody.rows];
        rows.sort((a, b) => {
          const va = a.dataset[key], vb = b.dataset[key];
          const na = Number(va), nb = Number(vb);
          const isNumA = !Number.isNaN(na) && va !== '';
          const isNumB = !Number.isNaN(nb) && vb !== '';
          if (isNumA && isNumB) {
            return na - nb;
          }
          return String(va).localeCompare(String(vb));
        });
        const dir = btn.dataset.dir = -(Number(btn.dataset.dir) || 1);
        if (dir < 0) rows.reverse();
        rows.forEach((row) => tbody.append(row));
      });
    });

    const chartXSelect = document.getElementById('chart-x');
    const chartYSelect = document.getElementById('chart-y');
    if (chartXSelect && chartYSelect) {
      chartXSelect.addEventListener('change', () => renderScatter(chartXSelect.value, chartYSelect.value));
      chartYSelect.addEventListener('change', () => renderScatter(chartXSelect.value, chartYSelect.value));
    }
  }
}

// Developer Tools Toggle
const toggleBtn = document.getElementById('toggle-dev-tools');
const statusText = document.getElementById('dev-tools-status');

if (toggleBtn && statusText) {
  const updateStatus = () => {
    const isEnabled = localStorage.getItem('lu:enable-dev-themer') === 'true';
    if (isEnabled) {
      toggleBtn.textContent = 'Disable Developer Tools';
      toggleBtn.classList.remove('btn-secondary');
      toggleBtn.classList.add('btn-primary');
      statusText.textContent = 'Currently Enabled (floating "+" button visible at bottom-right)';
      statusText.classList.remove('text-light-muted', 'dark:text-dark-muted');
      statusText.classList.add('text-primary');
    } else {
      toggleBtn.textContent = 'Enable Developer Tools';
      toggleBtn.classList.remove('btn-primary');
      toggleBtn.classList.add('btn-secondary');
      statusText.textContent = 'Currently Disabled';
      statusText.classList.remove('text-primary');
      statusText.classList.add('text-light-muted', 'dark:text-dark-muted');
    }
  };

  toggleBtn.addEventListener('click', () => {
    const isEnabled = localStorage.getItem('lu:enable-dev-themer') === 'true';
    localStorage.setItem('lu:enable-dev-themer', isEnabled ? 'false' : 'true');
    window.dispatchEvent(new Event('lu:toggle-dev-themer'));
    updateStatus();
  });

  updateStatus();
}
</script>
