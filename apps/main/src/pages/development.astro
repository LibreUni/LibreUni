        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-light-muted dark:text-dark-muted">PCA reduces eight numeric course metrics into principal components. The scree plot shows how much variance each component captures; the scatter plot projects courses onto the first two components, with k-means clusters and flagged outliers.</p>

        <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
          <div class="rounded-2xl border border-light-border bg-white p-6 dark:border-dark-border dark:bg-dark-bg">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Scree Plot</p>
            <p class="mt-1 text-sm text-light-muted dark:text-dark-muted">Variance explained per principal component</p>
            <svg id="scree-plot" class="mt-4 hidden h-64 w-full" viewBox="0 0 800 260" role="img" aria-label="PCA scree plot showing variance explained by each component"></svg>
            <p id="scree-summary" class="mt-2 text-xs leading-relaxed text-light-muted dark:text-dark-muted"></p>
          </div>

          <div class="rounded-2xl border border-light-border bg-white p-6 dark:border-dark-border dark:bg-dark-bg">
            <div class="flex flex-wrap items-end justify-between gap-2">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Component Space</p>
                <p class="mt-1 text-sm text-light-muted dark:text-dark-muted">Course positions on PCA axes</p>
              </div>
              <div class="flex gap-3 text-xs font-bold text-light-text dark:text-dark-text">
                <label>X <select id="chart-x" class="ml-1 rounded-lg border border-light-border bg-light-bg px-2 py-1 dark:border-dark-border dark:bg-dark-surface"><option value="pca1">PCA 1</option><option value="characters">Total characters</option><option value="lessons">Lessons</option><option value="modules">Modules</option><option value="charactersPerLesson">Chars / lesson</option><option value="charactersPerModule">Chars / module</option><option value="lessonsPerModule">Lessons / module</option><option value="averageWords">Avg words</option><option value="qualityScore">Quality score</option></select></label>
                <label>Y <select id="chart-y" class="ml-1 rounded-lg border border-light-border bg-light-bg px-2 py-1 dark:border-dark-border dark:bg-dark-surface"><option value="pca2">PCA 2</option><option value="characters">Total characters</option><option value="lessons">Lessons</option><option value="modules">Modules</option><option value="charactersPerLesson">Chars / lesson</option><option value="charactersPerModule">Chars / module</option><option value="lessonsPerModule">Lessons / module</option><option value="averageWords">Avg words</option><option value="qualityScore">Quality score</option></select></label>
              </div>
            </div>
            <svg id="scatter-plot" class="mt-4 hidden h-64 w-full" viewBox="0 0 800 300" role="img" aria-label="Course metrics scatter plot on PCA axes"></svg>
            <p id="chart-tooltip" class="mt-1 text-xs font-bold text-light-muted dark:text-dark-muted"></p>
          </div>
        </div>

        <p id="chart-summary" class="mt-6 text-sm leading-relaxed text-light-muted dark:text-dark-muted"></p>
      </div>
    </section>

    <section class="border-t border-light-border bg-white px-6 py-12 dark:border-dark-border dark:bg-dark-bg md:px-8 md:py-16">
      <div class="mx-auto max-w-7xl">
        <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Course Metrics</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-light-text dark:text-dark-text">Content by course</h2>
        <div class="mt-8 overflow-x-auto rounded-2xl border border-light-border bg-white dark:border-dark-border dark:bg-dark-bg">
          <table class="w-full min-w-[68rem] text-left text-sm">
            <thead class="border-b border-light-border text-xs uppercase tracking-wider text-light-muted dark:border-dark-border dark:text-dark-muted">
              <tr>
                <th class="px-5 py-4"><button data-sort="title" class="font-black">Course</button></th><th class="px-5 py-4"><button data-sort="status" class="font-black">Status</button></th><th class="px-5 py-4"><button data-sort="lessons" class="font-black">Lessons</button></th><th class="px-5 py-4"><button data-sort="modules" class="font-black">Modules</button></th><th class="px-5 py-4"><button data-sort="characters" class="font-black">Characters</button></th><th class="px-5 py-4"><button data-sort="charactersPerModule" class="font-black">Chars / module</button></th><th class="px-5 py-4"><button data-sort="charactersPerLesson" class="font-black">Chars / lesson</button></th><th class="px-5 py-4"><button data-sort="lessonsPerModule" class="font-black">Lessons / module</button></th><th class="px-5 py-4"><button data-sort="averageWords" class="font-black">Avg words</button></th><th class="px-5 py-4">Quality</th>
              </tr>
            </thead>
            <tbody id="course-metrics" class="divide-y divide-light-border dark:divide-dark-border">
              {courseMetrics.map((metric) => (
                <tr class="align-top" data-title={metric.course.data.title} data-status={metric.course.data.status} data-lessons={metric.lessons} data-modules={metric.modules} data-characters={metric.characters} data-characters-per-module={metric.charactersPerModule} data-characters-per-lesson={metric.charactersPerLesson} data-lessons-per-module={metric.lessonsPerModule} data-average-words={metric.averageWords} data-quality-score={metric.qualityScore}>
                  <td class="px-5 py-4 font-black text-light-text dark:text-dark-text">{metric.course.data.title}</td>
                  <td class="px-5 py-4"><span class="rounded-full bg-primary/10 px-2.5 py-1 text-xs font-black uppercase tracking-wider text-primary">{metric.course.data.status}</span></td>
                  <td class="px-5 py-4 font-bold text-light-text dark:text-dark-text">{metric.lessons}</td>
                  <td class="px-5 py-4 font-bold text-light-text dark:text-dark-text">{metric.modules}</td>
                  <td class="px-5 py-4 font-bold text-light-text dark:text-dark-text">{formatNumber.format(metric.characters)}</td>
                  <td class="px-5 py-4 font-bold text-light-text dark:text-dark-text">{formatNumber.format(metric.charactersPerModule)}</td>
                  <td class="px-5 py-4 font-bold text-light-text dark:text-dark-text">{formatNumber.format(metric.charactersPerLesson)}</td>
                  <td class="px-5 py-4 font-bold text-light-text dark:text-dark-text">{metric.lessonsPerModule}</td>
                  <td class="px-5 py-4 font-bold text-light-text dark:text-dark-text">{formatNumber.format(metric.averageWords)}</td>
                  <td class="px-5 py-4 text-light-muted dark:text-dark-muted">{(metric.quality as any)?.overall?.label ?? 'Not measured'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="border-t border-light-border bg-light-surface/50 px-6 py-12 dark:border-dark-border dark:bg-dark-surface/40 md:px-8 md:py-16">
      <div class="mx-auto max-w-7xl">
        <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Course Health</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-light-text dark:text-dark-text">Warnings and Improvement Points</h2>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-light-muted dark:text-dark-muted">Automated checks flagging courses that need attention. Warnings are generated from quality data and statistical analysis of content metrics.</p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <span class="inline-flex items-center gap-1.5 rounded-full border-2 border-light-border bg-light-surface px-4 py-1.5 text-sm font-black dark:border-dark-border dark:bg-dark-surface">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-light-text text-xs text-light-bg dark:bg-dark-text dark:text-dark-bg">!</span>
            High <span id="high-count" class="text-light-muted dark:text-dark-muted">0</span>
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-light-border bg-light-surface px-4 py-1.5 text-sm font-black dark:border-dark-border dark:bg-dark-surface">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-light-muted text-xs text-light-bg dark:bg-dark-muted dark:text-dark-bg">?</span>
            Medium <span id="medium-count" class="text-light-muted dark:text-dark-muted">0</span>
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-dashed border-light-border bg-light-surface px-4 py-1.5 text-sm font-black dark:border-dark-border dark:bg-dark-surface">
            <span class="flex h-5 w-5 items-center justify-center rounded-full border border-light-border text-xs text-light-muted dark:border-dark-border dark:text-dark-muted">i</span>
            Low <span id="low-count" class="text-light-muted dark:text-dark-muted">0</span>
          </span>
        </div>

        <div class="mt-6 flex flex-wrap gap-2">
          <button data-filter="all" class="filter-btn rounded-xl border border-light-border bg-light-surface px-4 py-2 text-xs font-black uppercase tracking-wider text-light-text transition-all hover:bg-light-text hover:text-light-bg dark:border-dark-border dark:bg-dark-surface dark:text-dark-text dark:hover:bg-dark-text dark:hover:text-dark-bg">All</button>
          <button data-filter="high" class="filter-btn rounded-xl border border-light-border bg-light-surface px-4 py-2 text-xs font-black uppercase tracking-wider text-light-text transition-all hover:bg-light-text hover:text-light-bg dark:border-dark-border dark:bg-dark-surface dark:text-dark-text dark:hover:bg-dark-text dark:hover:text-dark-bg">High</button>
          <button data-filter="medium" class="filter-btn rounded-xl border border-light-border bg-light-surface px-4 py-2 text-xs font-black uppercase tracking-wider text-light-text transition-all hover:bg-light-text hover:text-light-bg dark:border-dark-border dark:bg-dark-surface dark:text-dark-text dark:hover:bg-dark-text dark:hover:text-dark-bg">Medium</button>
          <button data-filter="low" class="filter-btn rounded-xl border border-light-border bg-light-surface px-4 py-2 text-xs font-black uppercase tracking-wider text-light-text transition-all hover:bg-light-text hover:text-light-bg dark:border-dark-border dark:bg-dark-surface dark:text-dark-text dark:hover:bg-dark-text dark:hover:text-dark-bg">Low</button>
        </div>

        <div id="warnings-list" class="mt-6 space-y-3"></div>
        <p id="warnings-empty" class="mt-8 hidden text-center text-sm text-light-muted dark:text-dark-muted">No warnings match this filter.</p>

        <div id="draft-warnings-container" class="mt-8 border-t border-light-border pt-6 dark:border-dark-border hidden">
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between text-sm font-bold text-light-muted transition hover:text-light-text dark:text-dark-muted dark:hover:text-dark-text select-none">
              <span class="flex items-center gap-2">
                <span>Draft/Hidden Course Warnings (Lower Priority)</span>
                <span class="rounded-full bg-light-surface px-2.5 py-0.5 text-xs font-black text-light-muted dark:bg-dark-surface dark:text-dark-muted border border-light-border dark:border-dark-border" id="draft-count">0</span>
              </span>
