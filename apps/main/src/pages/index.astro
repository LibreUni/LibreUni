---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { 
    Calculator, 
    LayoutIcon, 
    BookOpen,
    Code2,
    Brain,
    Cpu,
    FlaskConical,
    Shapes,
    Binary,
    ArrowRight,
    Users,
    GraduationCap,
    Compass
} from '../components/Icons';

const courses = await getCollection('courses');
const allLessons = await getCollection('lessons');
const careers = await getCollection('careers');

const iconMap: Record<string, any> = {
    calculator: Calculator,
    layout: LayoutIcon,
    code: Code2,
    brain: Brain,
    cpu: Cpu,
    science: FlaskConical,
    elements: Shapes,
    binary: Binary,
    book: BookOpen,
    users: Users,
    graduation: GraduationCap,
    compass: Compass
};

---

<Layout title="LibreUni - Mastery starts here">
  <div class="flex-1">
    <!-- Hero Section -->
    <section class="relative min-h-[85vh] flex items-center justify-center px-8 overflow-hidden bg-white dark:bg-dark-bg">
        <!-- Floating shapes background -->
        <div class="absolute inset-0 z-0 text-primary/5 dark:text-primary/10">
            <svg class="absolute top-0 left-0 w-full h-full opacity-50" viewBox="0 0 100 100" preserveAspectRatio="none">
                <defs>
                    <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
                        <path d="M 10 0 L 0 0 0 10" fill="none" stroke="currentColor" stroke-width="0.1"/>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)" />
            </svg>
        </div>
        <div class="absolute inset-0 z-0">
            <div class="absolute top-1/4 -left-20 w-96 h-96 bg-primary/20 rounded-full blur-[100px] animate-pulse-soft"></div>
            <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-secondary/20 rounded-full blur-[100px] animate-pulse-soft" style="animation-delay: 2s"></div>
        </div>

        <div class="relative z-10 max-w-5xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/5 border border-primary/20 mb-8 animate-float">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                </span>
                <span class="text-xs font-bold uppercase tracking-widest text-primary">EVERYTHING IS FREE</span>
            </div>
            
            <h1 class="text-4xl sm:text-7xl md:text-8xl font-[900] mb-8 tracking-tight leading-[0.9] text-light-text dark:text-dark-text break-words">
                MASTER THE <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-accent animate-gradient-x">FUNDAMENTALS</span>
            </h1>
            
            <p class="text-lg md:text-2xl text-light-muted dark:text-dark-muted mb-12 max-w-2xl mx-auto font-medium leading-relaxed px-4">
                University-level education, completely free. <br class="hidden md:block" /> Interactive. Precise. No fluff.
            </p>
            
            <div class="flex flex-col sm:flex-row justify-center gap-4 sm:gap-6 px-6">
                 <button 
                  onclick="document.getElementById('career-paths').scrollIntoView({behavior: 'smooth'})" 
                  class="group relative bg-primary text-white px-10 py-5 rounded-2xl font-bold text-lg transition-all hover:scale-105 active:scale-95 shadow-2xl shadow-primary/20 flex items-center justify-center overflow-hidden"
                 >
                    <div class="absolute inset-0 bg-white/10 group-hover:translate-x-full transition-transform duration-500 -skew-x-12"></div>
                    <span class="relative">Career Paths</span>
                    <Compass className="relative inline-block ml-2 group-hover:translate-x-1 transition-transform" />
                 </button>
                 <button 
                  onclick="document.getElementById('courses-grid').scrollIntoView({behavior: 'smooth'})" 
                  class="group relative bg-white dark:bg-dark-surface border-2 border-primary text-primary px-10 py-5 rounded-2xl font-bold text-lg transition-all hover:scale-105 active:scale-95 flex items-center justify-center overflow-hidden"
                 >
                    <span class="relative">All Tracks</span>
                    <ArrowRight className="relative inline-block ml-2 group-hover:translate-x-1 transition-transform" />
                 </button>
            </div>
        </div>
    </section>

    <!-- Career Paths Section -->
    <section class="max-w-7xl mx-auto pt-32 px-8" id="career-paths">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
            <div class="relative">
                <h2 class="text-6xl font-black tracking-tighter text-light-text dark:text-dark-text uppercase leading-none">Career<br/>Paths</h2>
                <div class="absolute -bottom-4 left-0 h-4 w-24 bg-secondary/20 -skew-x-12"></div>
            </div>
            <p class="max-w-md text-light-muted dark:text-dark-muted font-medium italic text-lg border-l-4 border-secondary/20 pl-6">
                Structured curriculums for specific industry roles. Track your progress across multiple disciplines.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {careers.map((career) => {
                const Icon = iconMap[career.data.icon] || GraduationCap;
                
                return (
                    <a 
                        href={`${import.meta.env.BASE_URL}careers/${career.id}`}
                        class="group relative bg-white dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-[3rem] p-10 transition-all duration-500 hover:-translate-y-4 hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.15)] overflow-hidden flex flex-col h-full"
                    >
                        <div class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-br ${career.data.color} opacity-10 group-hover:opacity-20 transition-all duration-700 blur-2xl`}></div>
                        
                        <div class="relative z-10 flex flex-col h-full">
                            <div class="flex justify-between items-start mb-8">
                                <div class={`p-5 rounded-3xl bg-primary bg-gradient-to-br ${career.data.color} text-white shadow-xl group-hover:scale-110 transition-transform`}>
                                    <Icon size={28} strokeWidth={2.5} />
                                </div>
                                <div class="career-progress hidden flex flex-col items-end gap-1" data-career-id={career.id}>
                                    <span class="text-[10px] font-black uppercase text-primary tracking-widest">Progress</span>
                                    <span class="progress-text text-xl font-black tabular-nums">0%</span>
                                </div>
                            </div>
                            
                            <h3 class="text-2xl font-black mb-4 tracking-tight leading-tight group-hover:text-primary transition-colors">{career.data.title}</h3>
                            <p class="text-light-muted dark:text-dark-muted font-medium text-sm line-clamp-3 mb-10 italic">
                                {career.data.description}
                            </p>
                            
                            <div class="mt-auto pt-6 border-t border-light-border dark:border-dark-border flex items-center justify-between">
                                <span class="text-[10px] font-black uppercase tracking-widest opacity-50">{career.data.steps.length} Phases</span>
                                <div class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary">
                                    View Path
                                    <ArrowRight size={16} className="group-hover:translate-x-1 transition-transform" />
                                </div>
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>
    </section>

    <main class="max-w-7xl mx-auto py-32 px-8" id="courses-grid">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-24 gap-8">
            <div class="relative">
                <h2 class="text-6xl font-black tracking-tighter text-light-text dark:text-dark-text uppercase leading-none">Explore<br/>Tracks</h2>
                <div class="absolute -bottom-4 left-0 h-4 w-24 bg-primary/20 -skew-x-12"></div>
            </div>
            
            <div class="flex-1 max-w-md">
                <div class="mb-4 text-[10px] font-black uppercase tracking-[0.2em] text-light-muted dark:text-dark-muted">Filter Tracks</div>
                <div class="relative">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-light-muted dark:text-dark-muted pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <input 
                        type="text" 
                        id="course-search"
                        placeholder="Search courses..." 
                        class="w-full bg-white dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-2xl pl-11 pr-4 py-3 text-sm font-bold focus:outline-none focus:border-primary transition-all dark:text-white"
                    />
                </div>
            </div>

            <p class="max-w-md text-light-muted dark:text-dark-muted font-medium italic text-lg border-l-4 border-primary/20 pl-6">
                Deep dive into professional roadmaps designed for engineers and scientists.
            </p>
        </div>

        <div class="mb-12 border-b border-light-border dark:border-dark-border">
            <div class="flex flex-wrap gap-4 mb-8">
                <button type="button" class="filter-btn active px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-primary bg-primary text-white transition-all" data-category="all">All Tracks</button>
                <button type="button" class="filter-btn px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:border-primary hover:text-primary transition-all" data-category="math">Mathematics</button>
                <button type="button" class="filter-btn px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:border-primary hover:text-primary transition-all" data-category="cs">Computer Science</button>
                <button type="button" class="filter-btn px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:border-primary hover:text-primary transition-all" data-category="ai">AI & ML</button>
                <button type="button" class="filter-btn px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:border-primary hover:text-primary transition-all" data-category="dev">Development</button>
                <button type="button" class="filter-btn px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:border-primary hover:text-primary transition-all" data-category="phil">Philosophy</button>
                <button type="button" class="filter-btn px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:border-primary hover:text-primary transition-all" data-category="mgmt">Management</button>
                <button type="button" class="filter-btn px-8 py-3 rounded-xl font-black text-[11px] uppercase tracking-widest border-2 border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:border-primary hover:text-primary transition-all" data-category="other">Misc</button>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {courses.map((course) => {
            const Icon = iconMap[course.data.icon] || BookOpen;
            const isCustomIcon = course.data.icon.includes('/') || course.data.icon.includes('.');
            
            // Basic tagging logic for pure JS filtering
            let category = 'other';
            if (course.id.startsWith('math')) category = 'math';
            else if (['c', 'cpp', 'operating-systems', 'software-engineering', 'software-architecture'].includes(course.id)) category = 'cs';
            else if (['machine-learning'].includes(course.id)) category = 'ai';
            else if (['philosophy', 'philosophy-science'].includes(course.id)) category = 'phil';
            else if (['git', 'uml', 'python', 'javascript', 'libreuni'].includes(course.id)) category = 'dev';
            else if (['team-dynamics'].includes(course.id)) category = 'mgmt';

            return (
              <a 
                href={`${import.meta.env.BASE_URL}courses/${course.id}`} 
                class="course-card group relative bg-white dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-[3rem] p-10 transition-all duration-500 hover:-translate-y-4 hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.15)] dark:hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.4)] overflow-hidden flex flex-col h-full"
                data-category={category}
              >
                {/* Decorative background circle */}
                <div class={`absolute -top-24 -right-24 w-64 h-64 rounded-full opacity-5 group-hover:opacity-10 transition-all duration-700 ${course.data.color}`}></div>
                
                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex justify-between items-start mb-16">
                        <div class="p-6 rounded-[2.5rem] bg-light-surface dark:bg-dark-bg text-light-text dark:text-dark-text shadow-lg group-hover:scale-110 group-hover:bg-primary group-hover:text-white transition-all duration-500 border border-light-border dark:border-dark-border">
                            {isCustomIcon ? (
                                <img src={course.data.icon} alt={course.data.title} class="w-8 h-8 object-contain" />
                            ) : (
                                <Icon size={32} strokeWidth={2.5} />
                            )}
                        </div>
                        <div class="px-5 py-2 rounded-full bg-light-accent dark:bg-dark-accent/20 text-[10px] font-black uppercase tracking-[0.2em] text-white dark:text-dark-text">
                            {allLessons.filter(l => l.data.course === course.id).length} Modules
                        </div>
                    </div>

                    <div class="mt-auto">
                        <h3 class="text-3xl font-black mb-4 tracking-tighter text-light-text dark:text-dark-text group-hover:translate-x-2 transition-transform duration-300">{course.data.title}</h3>
                        <p class="text-light-muted dark:text-dark-muted line-clamp-2 mb-10 font-medium italic text-base leading-relaxed">
                            {course.data.description}
                        </p>
                        
                        <div class="flex items-center gap-3 text-sm font-black uppercase tracking-[0.2em] group-hover:gap-6 transition-all text-primary">
                            Begin Track
                            <ArrowRight size={20} className="group-hover:translate-x-2 transition-transform" />
                        </div>
                    </div>
                </div>
              </a>
            );
          })}
        </div>
    </main>

    <footer class="py-24 px-8 text-center border-t border-light-border dark:border-dark-border bg-light-surface/50 dark:bg-dark-surface/50">
        <div class="max-w-xl mx-auto">
            <div class="flex items-center justify-center gap-3 mb-8">
                <div class="bg-primary p-2 rounded-xl shadow-lg shadow-primary/20">
                    <BookOpen size={24} strokeWidth={3} className="text-white" />
                </div>
                <span class="text-3xl font-black tracking-tighter text-light-text dark:text-dark-text">LibreUni</span>
            </div>
            <p class="text-lg font-bold text-light-muted dark:text-dark-muted italic mb-4">Dedicated to the democratization of knowledge.</p>
            <div class="flex justify-center gap-6 mb-12">
                <a href="https://libreuni.org" class="text-sm font-black uppercase tracking-widest hover:text-primary transition-colors">libreuni.org</a>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.3em] text-light-muted dark:text-dark-muted">© 2026 LIBREUNI PROJECT. EDUARD FEKETE</p>
        </div>
    </footer>
    
    <script is:inline>
        const buttons = document.querySelectorAll('.filter-btn');
        const cards = document.querySelectorAll('.course-card');
        const searchInput = document.getElementById('course-search');

        let currentCategory = 'all';
        let currentQuery = '';

        function updateFilters() {
            cards.forEach(card => {
                const category = card.getAttribute('data-category');
                const title = card.querySelector('h3').innerText.toLowerCase();
                const description = card.querySelector('p').innerText.toLowerCase();
                
                const matchesCategory = currentCategory === 'all' || category === currentCategory;
                const matchesSearch = title.includes(currentQuery) || description.includes(currentQuery);

                if (matchesCategory && matchesSearch) {
                    card.classList.remove('hidden');
                    card.style.opacity = "1";
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                currentCategory = btn.getAttribute('data-category');
                
                buttons.forEach(b => {
                    b.classList.remove('active', 'bg-primary', 'text-white', 'border-primary');
                    b.classList.add('text-light-muted', 'dark:text-dark-muted', 'border-light-border', 'dark:border-dark-border');
                });
                btn.classList.add('active', 'bg-primary', 'text-white', 'border-primary');
                btn.classList.remove('text-light-muted', 'dark:text-dark-muted', 'border-light-border', 'dark:border-dark-border');

                updateFilters();
            });
        });

        searchInput?.addEventListener('input', (e) => {
            currentQuery = e.target.value.toLowerCase();
            updateFilters();
        });

        // Career Progress Update
        function updateCareerProgress() {
            const careerBadges = document.querySelectorAll('.career-progress');
            careerBadges.forEach(badge => {
                const id = badge.getAttribute('data-career-id');
                const progress = localStorage.getItem(`career-progress-${id}`);
                if (progress !== null) {
                    badge.classList.remove('hidden');
                    badge.querySelector('.progress-text').innerText = `${progress}%`;
                }
            });
        }
        updateCareerProgress();
        window.addEventListener('storage', updateCareerProgress);
    </script>
  </div>
</Layout>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
