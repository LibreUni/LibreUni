---
import Layout from '../layouts/Layout.astro';
import Search from '../components/Search';
import {
    ArrowRight,
    BookOpen,
    Brain,
    Calculator,
    Code2,
    Compass,
    Cpu,
    FlaskConical,
    GraduationCap,
    LayoutIcon,
    Shapes,
    Users
} from '../components/Icons';
import { getCollection } from 'astro:content';

const courses = await getCollection('courses');
const lessons = await getCollection('lessons');
const careers = await getCollection('careers');

const featuredCourseIds = ['python', 'software-engineering', 'math-calculus', 'machine-learning', 'devops', 'philosophy'];
const featuredCourses = featuredCourseIds
    .map(id => courses.find(course => course.id === id))
    .filter(Boolean)
    .slice(0, 6);
const featuredCareers = careers.slice(0, 3);

const iconMap: Record<string, any> = {
    calculator: Calculator,
    layout: LayoutIcon,
    code: Code2,
    brain: Brain,
    cpu: Cpu,
    science: FlaskConical,
    elements: Shapes,
    book: BookOpen,
    users: Users,
    graduation: GraduationCap,
    compass: Compass
};
---

<Layout title="LibreUni - Mastery starts here">
  <div class="flex-1 bg-white dark:bg-dark-bg">
    <section class="relative overflow-hidden border-b border-light-border dark:border-dark-border">
        <div class="absolute inset-0 z-0 text-primary/5 dark:text-primary/10">
            <svg class="absolute inset-0 h-full w-full opacity-60" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                <defs>
                    <pattern id="home-grid" width="10" height="10" patternUnits="userSpaceOnUse">
                        <path d="M 10 0 L 0 0 0 10" fill="none" stroke="currentColor" stroke-width="0.1"/>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#home-grid)" />
            </svg>
        </div>

        <div class="relative z-10 mx-auto flex min-h-[calc(100vh-4rem)] max-w-7xl flex-col justify-center px-6 py-20 md:px-8">
            <div class="max-w-5xl">
                <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-2">
                    <span class="h-2 w-2 rounded-full bg-primary"></span>
                    <span class="text-xs font-black uppercase tracking-widest text-primary">Everything is free</span>
                </div>

                <h1 class="max-w-4xl text-5xl font-black uppercase leading-[0.95] tracking-tight text-light-text dark:text-dark-text md:text-7xl">
                    Master the fundamentals without the gatekeeping.
                </h1>

                <p class="mt-8 max-w-2xl text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted md:text-2xl">
                    University-level courses, role-based career paths, and topic-level lessons built for serious independent study.
                </p>
            </div>

            <div class="mt-12 max-w-3xl">
                <Search client:load baseUrl={import.meta.env.BASE_URL} variant="hero" />
            </div>

            <div class="mt-10 flex flex-col gap-4 sm:flex-row">
                <a href={`${import.meta.env.BASE_URL}courses`} class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-primary px-8 py-4 text-sm font-black uppercase tracking-widest text-white shadow-xl shadow-primary/20 transition-all hover:-translate-y-1">
                    Browse Courses
                    <ArrowRight size={18} className="transition-transform group-hover:translate-x-1" />
                </a>
                <a href={`${import.meta.env.BASE_URL}careers`} class="group inline-flex items-center justify-center gap-3 rounded-2xl border border-light-border bg-white px-8 py-4 text-sm font-black uppercase tracking-widest text-light-text transition-all hover:-translate-y-1 hover:border-primary hover:text-primary dark:border-dark-border dark:bg-dark-surface dark:text-dark-text">
                    Career Paths
                    <Compass size={18} className="transition-transform group-hover:translate-x-1" />
                </a>
            </div>
        </div>
    </section>

    <section class="mx-auto grid max-w-7xl gap-6 px-6 py-16 md:grid-cols-3 md:px-8">
        <div class="border-b border-light-border pb-8 dark:border-dark-border md:border-b-0 md:border-r md:pr-8">
            <p class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text">{courses.length}</p>
            <p class="mt-2 text-xs font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Courses</p>
        </div>
        <div class="border-b border-light-border pb-8 dark:border-dark-border md:border-b-0 md:border-r md:px-8">
            <p class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text">{lessons.length}</p>
            <p class="mt-2 text-xs font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Lessons and topics</p>
        </div>
        <div class="md:pl-8">
            <p class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text">{careers.length}</p>
            <p class="mt-2 text-xs font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Career paths</p>
        </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20 md:px-8">
        <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="mb-3 text-xs font-black uppercase tracking-[0.25em] text-primary">Featured Courses</p>
                <h2 class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text md:text-5xl">Start with a strong track.</h2>
            </div>
            <a href={`${import.meta.env.BASE_URL}courses`} class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-widest text-primary">
                All Courses
                <ArrowRight size={16} />
            </a>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {featuredCourses.map((course) => {
                const Icon = iconMap[course.data.icon] || BookOpen;
                const lessonCount = lessons.filter(lesson => lesson.data.course === course.id).length;

                return (
                    <a href={`${import.meta.env.BASE_URL}courses/${course.id}`} class="group flex min-h-64 flex-col rounded-2xl border border-light-border bg-white p-8 transition-all hover:-translate-y-1 hover:border-primary/50 hover:shadow-2xl hover:shadow-slate-200/70 dark:border-dark-border dark:bg-dark-surface dark:hover:shadow-black/30">
                        <div class="mb-10 flex items-start justify-between">
                            <div class="rounded-2xl border border-light-border bg-light-surface p-4 text-light-text transition-all group-hover:bg-primary group-hover:text-white dark:border-dark-border dark:bg-dark-bg dark:text-dark-text">
                                <Icon size={28} strokeWidth={2.5} />
                            </div>
                            <span class="rounded-full bg-primary/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-primary">{lessonCount} Lessons</span>
                        </div>
                        <div class="mt-auto">
                            <h3 class="text-2xl font-black tracking-tight text-light-text transition-colors group-hover:text-primary dark:text-dark-text">{course.data.title}</h3>
                            <p class="mt-3 line-clamp-2 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">{course.data.description}</p>
                        </div>
                    </a>
                );
            })}
        </div>
    </section>

    <section class="border-y border-light-border bg-light-surface/60 dark:border-dark-border dark:bg-dark-surface/40">
        <div class="mx-auto max-w-7xl px-6 py-20 md:px-8">
            <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
                <div>
                    <p class="mb-3 text-xs font-black uppercase tracking-[0.25em] text-primary">Career Paths</p>
                    <h2 class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text md:text-5xl">Study toward a role.</h2>
                </div>
                <a href={`${import.meta.env.BASE_URL}careers`} class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-widest text-primary">
                    View Paths
                    <ArrowRight size={16} />
                </a>
            </div>

            <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
                {featuredCareers.map((career) => {
                    const Icon = iconMap[career.data.icon] || GraduationCap;

                    return (
                        <a href={`${import.meta.env.BASE_URL}careers/${career.id}`} class="group rounded-2xl border border-light-border bg-white p-8 transition-all hover:-translate-y-1 hover:border-primary/50 hover:shadow-2xl hover:shadow-slate-200/70 dark:border-dark-border dark:bg-dark-bg dark:hover:shadow-black/30">
                            <div class={`mb-8 inline-flex rounded-2xl bg-gradient-to-br ${career.data.color} p-4 text-white`}>
                                <Icon size={28} strokeWidth={2.5} />
                            </div>
                            <h3 class="text-2xl font-black tracking-tight text-light-text transition-colors group-hover:text-primary dark:text-dark-text">{career.data.title}</h3>
                            <p class="mt-3 line-clamp-3 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">{career.data.description}</p>
                            <div class="mt-8 flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary">
                                {career.data.steps.length} Phases
                                <ArrowRight size={15} className="transition-transform group-hover:translate-x-1" />
                            </div>
                        </a>
                    );
                })}
            </div>
        </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20 md:px-8">
        <div class="grid gap-10 md:grid-cols-[1fr_1.5fr] md:items-center">
            <div>
                <p class="mb-3 text-xs font-black uppercase tracking-[0.25em] text-primary">About LibreUni</p>
                <h2 class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text md:text-5xl">Free education with academic teeth.</h2>
            </div>
            <div class="space-y-6 text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                <p>LibreUni is built around self-contained courses, rigorous explanations, and interactive practice where it improves understanding.</p>
                <a href={`${import.meta.env.BASE_URL}about`} class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-widest text-primary">
                    Read More
                    <ArrowRight size={16} />
                </a>
            </div>
        </div>
    </section>
  </div>
</Layout>
