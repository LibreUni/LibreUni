{
  "name": "libreuni",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:main",
    "dev:main": "npm run dev --workspace=@libreuni/main",
    "dev:lang": "npm run dev --workspace=@libreuni/lang",
    "dev:history": "npm run dev --workspace=@libreuni/history",
    "build": "node tools/run-workspace-script.mjs build",
    "build:all": "npm run build:main && npm run build:lang && npm run build:history",
    "build:main": "npm run build --workspace=@libreuni/main",
    "build:lang": "npm run build --workspace=@libreuni/lang",
    "build:history": "npm run build --workspace=@libreuni/history",
    "preview": "node tools/run-workspace-script.mjs preview",
    "preview:main": "npm run preview --workspace=@libreuni/main",
    "preview:lang": "npm run preview --workspace=@libreuni/lang",
    "preview:history": "npm run preview --workspace=@libreuni/history",
    "test": "npm run test:build && npm run test:e2e:run && npm run test:ux:run && npm run test:lighthouse:run",
    "test:install": "playwright install chromium",
    "test:build": "npm run build:all",
    "test:e2e": "npm run test:build && npm run test:e2e:run",
    "test:e2e:run": "playwright test --project=chromium --project=mobile-chrome",
    "test:ux": "npm run test:build && npm run test:ux:run",
    "test:ux:run": "playwright test --project=ux",
    "test:lighthouse": "npm run test:build && npm run test:lighthouse:run",
    "test:lighthouse:run": "node tools/run-lighthouse-ci.mjs",
    "test:report": "playwright show-report reports/playwright"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cantoo/color-blindness": "^1.0.5",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "colorjs.io": "^0.6.1"
  }
}
