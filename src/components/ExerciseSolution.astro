---
import katex from 'katex';

const { hint } = Astro.props;

// Process inline math $...$ in hint prop since it bypasses remark-math
let hintHtml = '';
if (hint) {
  hintHtml = hint.replace(/\$([^$]+)\$/g, (_, math) => {
    try {
      return katex.renderToString(math.trim(), {
        displayMode: false,
        output: 'mathml',
        throwOnError: true,
        strict: 'error',
      });
    } catch {
      return `$${math}$`;
    }
  });
}
---

{
  hint ? (
    <details class="exercise-solution group">
      <summary class="exercise-solution-summary cursor-pointer rounded-lg border border-primary/20 px-4 py-2 font-semibold text-primary transition-colors hover:bg-primary/5">
        Show hint
      </summary>
      <div class="exercise-hint-content mt-3 rounded-lg border-l-4 border-amber-500/40 bg-amber-500/5 px-4 py-3 text-sm italic text-light-muted dark:text-dark-muted" set:html={hintHtml}>
      </div>
      <details class="exercise-solution mt-3 group">
        <summary class="exercise-solution-summary cursor-pointer rounded-lg border border-primary/20 px-4 py-2 font-semibold text-primary transition-colors hover:bg-primary/5">
          Show solution
        </summary>
        <div class="exercise-solution-content mt-3 rounded-lg border-l-4 border-emerald-500/40 bg-emerald-500/5 px-4 py-3">
          <slot />
        </div>
      </details>
    </details>
  ) : (
    <details class="exercise-solution group">
      <summary class="exercise-solution-summary cursor-pointer rounded-lg border border-primary/20 px-4 py-2 font-semibold text-primary transition-colors hover:bg-primary/5">
        Show solution
      </summary>
      <div class="exercise-solution-content mt-3 rounded-lg border-l-4 border-emerald-500/40 bg-emerald-500/5 px-4 py-3">
        <slot />
      </div>
    </details>
  )
}
