---
interface Props {
  src: string;
  title: string;
  height?: string;
}

const { src, title, height = '28rem' } = Astro.props;
---

<figure class="interactive-embed my-12 overflow-hidden rounded-[2rem] border border-light-border bg-light-surface p-4 shadow-xl dark:border-dark-border dark:bg-dark-surface md:p-6" data-embed-src={src}>
  <div class="interactive-embed-screen">
    <iframe
      src={src}
      title={title}
      loading="lazy"
      sandbox="allow-scripts"
      style={`height: ${height}`}
      class="w-full rounded-2xl border border-light-border bg-white dark:border-dark-border"
    ></iframe>
  </div>
  <div class="interactive-embed-print">
    <div class="label-caps">Interactive supplement omitted from print</div>
    <p class="mt-2 text-sm text-slate-600">{title}. Open the digital lesson to use this embedded exploration.</p>
  </div>
</figure>
