---
import katex from 'katex';

interface Props {
  math: string;
  block?: boolean;
}

const { math, block } = Astro.props;
const html = katex.renderToString(math, {
  throwOnError: false,
  displayMode: block,
  output: 'mathml' // Match the config for consistency and size
});
---

{block ? (
  <div class="not-prose my-8 overflow-x-auto text-center" set:html={html} />
) : (
  <span class="not-prose" set:html={html} />
)}
