---
interface Props {
  id: string;
  for: string;
  title?: string;
  collapsible?: boolean;
  open?: boolean;
}

const {
  id,
  for: statementId,
  title = 'Proof',
  collapsible = false,
  open = false,
} = Astro.props;

const headingId = `${id}-heading`;
const statementHref = `#${statementId}`;
---

<section id={id} class="math-proof my-6 scroll-mt-24 rounded-2xl border border-light-border bg-light-surface/60 p-5 dark:border-dark-border dark:bg-dark-surface/60 md:p-6" aria-labelledby={headingId}>
  {collapsible ? (
    <details open={open}>
      <summary id={headingId} class="flex cursor-pointer list-none items-center justify-between gap-3 text-base font-bold text-light-text dark:text-dark-text marker:hidden">
        <span class="flex items-center gap-2"><span aria-hidden="true">∎</span>{title}</span>
      </summary>
      <div class="mt-4 border-t border-light-border pt-4 leading-relaxed text-light-text dark:border-dark-border dark:text-dark-text">
        <slot />
        <p class="mt-4 mb-0"><a href={statementHref} class="text-xs font-semibold text-primary no-underline hover:underline">Back to statement ↑</a></p>
      </div>
    </details>
  ) : (
    <>
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h3 id={headingId} class="m-0 flex items-center gap-2 text-base font-bold text-light-text dark:text-dark-text"><span aria-hidden="true">∎</span>{title}</h3>
        <a href={statementHref} class="text-xs font-semibold text-primary no-underline hover:underline">Back to statement ↑</a>
      </div>
      <div class="mt-4 leading-relaxed text-light-text dark:text-dark-text">
        <slot />
      </div>
    </>
  )}
</section>
