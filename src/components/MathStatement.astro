---
type StatementKind = 'definition' | 'lemma' | 'theorem' | 'proposition' | 'corollary' | 'example' | 'remark';

interface Reference {
  id: string;
  label: string;
}

interface Props {
  id: string;
  kind?: StatementKind;
  title: string;
  number?: string;
  proofId?: string;
  dependsOn?: Reference[];
}

const {
  id,
  kind = 'theorem',
  title,
  number,
  proofId,
  dependsOn = [],
} = Astro.props;

const label = kind.charAt(0).toUpperCase() + kind.slice(1);
const statementLabel = number ? `${label} ${number}` : label;
---

<section id={id} data-math-statement class={`math-statement math-statement-${kind} my-8 scroll-mt-24 rounded-2xl border p-5 md:p-6`} aria-labelledby={`${id}-heading`}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <h3 id={`${id}-heading`} class="m-0 flex items-baseline gap-2 text-lg font-bold leading-snug text-light-text dark:text-dark-text">
      <span class="shrink-0 text-xs font-black uppercase tracking-[0.16em] text-primary">{statementLabel}</span>
      <span>{title}</span>
    </h3>
    {proofId && (
      <a href={`#${proofId}`} class="shrink-0 rounded-md border border-primary/20 px-2.5 py-1 text-xs font-semibold text-primary no-underline transition-colors hover:bg-primary/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
        Read proof ↓
      </a>
    )}
  </div>

  {dependsOn.length > 0 && (
    <p class="mt-3 text-xs font-medium text-light-muted dark:text-dark-muted">
      Builds on:
      {dependsOn.map((reference, index) => (
        <span>
          {index > 0 && ', '}
          <a href={`#${reference.id}`} class="text-primary underline decoration-primary/30 underline-offset-2 hover:decoration-primary">{reference.label}</a>
        </span>
      ))}
    </p>
  )}

  <div class="mt-4 leading-relaxed text-light-text dark:text-dark-text">
    <slot />
  </div>

  <template data-math-preview>
    <div class="math-preview-content">
      <div class="math-preview-label">{statementLabel}</div>
      <div class="math-preview-title">{title}</div>
      <div class="math-preview-body"><slot /></div>
    </div>
  </template>
</section>

<script>
  const setupMathPreviews = () => {
    if (document.documentElement.dataset.mathPreviewsReady) return;
    document.documentElement.dataset.mathPreviewsReady = 'true';

    const links = document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]');
    let tooltip: HTMLDivElement | null = null;
    let hideTimer: number | undefined;

    const getStatement = (link: HTMLAnchorElement) => {
      const id = decodeURIComponent(link.getAttribute('href')?.slice(1) || '');
      if (!id) return null;
      return Array.from(document.querySelectorAll<HTMLElement>('[data-math-statement]'))
        .find((statement) => statement.id === id) || null;
    };

    const hide = () => {
      if (tooltip) tooltip.remove();
      tooltip = null;
    };

    const show = (link: HTMLAnchorElement) => {
      window.clearTimeout(hideTimer);
      const statement = getStatement(link);
      const source = statement?.querySelector<HTMLTemplateElement>('template[data-math-preview]');
      if (!source) return;

      hide();
      tooltip = document.createElement('div');
      tooltip.className = 'math-preview-tooltip';
      tooltip.setAttribute('role', 'tooltip');
      tooltip.append(source.content.cloneNode(true));
      document.body.append(tooltip);
      link.setAttribute('aria-describedby', 'math-preview-tooltip');
      tooltip.id = 'math-preview-tooltip';

      const rect = link.getBoundingClientRect();
      const margin = 12;
      const width = Math.min(480, window.innerWidth - margin * 2);
      tooltip.style.width = `${width}px`;
      const tooltipRect = tooltip.getBoundingClientRect();
      const left = Math.max(margin, Math.min(rect.left, window.innerWidth - tooltipRect.width - margin));
      const above = rect.top - tooltipRect.height - margin;
      const top = above >= margin ? above : Math.min(window.innerHeight - tooltipRect.height - margin, rect.bottom + margin);
      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${Math.max(margin, top)}px`;
    };

    links.forEach((link) => {
      if (!getStatement(link)) return;
      link.addEventListener('pointerenter', () => show(link));
      link.addEventListener('pointerleave', () => {
        hideTimer = window.setTimeout(hide, 80);
      });
      link.addEventListener('focus', () => show(link));
      link.addEventListener('blur', hide);
    });

    window.addEventListener('scroll', hide, { passive: true });
    window.addEventListener('resize', hide, { passive: true });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupMathPreviews, { once: true });
  } else {
    setupMathPreviews();
  }
</script>
