---
import fs from 'node:fs';
import path from 'node:path';
import crypto from 'node:crypto';
import { execFileSync } from 'node:child_process';
import { highlightCode } from './SyntaxHighlighter';

interface Props {
  code: string;
  format?: 'svg' | 'png';
  title?: string;
  bookOnly?: boolean;
}

const { code, format = 'svg', title = 'Python Diagram Source', bookOnly = false } = Astro.props;

const processedCode = code.trim();
const highlightedCode = highlightCode(processedCode);
const CACHE_DIR = path.resolve('./src/python-diagram-cache');
if (!fs.existsSync(CACHE_DIR)) {
  fs.mkdirSync(CACHE_DIR, { recursive: true });
}

const ERROR_LOG = path.resolve('./python-diagram-errors.log');
const hash = crypto.createHash('md5').update(processedCode + format).digest('hex');
const cacheFile = path.join(CACHE_DIR, `${hash}.${format}`);
const workDir = path.join(CACHE_DIR, hash);

const escapeHtml = (value: string) => value
  .replace(/&/g, '&amp;')
  .replace(/</g, '&lt;')
  .replace(/>/g, '&gt;')
  .replace(/"/g, '&quot;');

const normalizeSvg = (svg: string) => {
  let normalized = svg.trim();
  if (/\spreserveAspectRatio\s*=/.test(normalized)) {
    normalized = normalized.replace(/\spreserveAspectRatio\s*=\s*["'][^"']*["']/i, ' preserveAspectRatio="xMidYMid meet"');
  } else {
    normalized = normalized.replace(/<svg\b/i, '<svg preserveAspectRatio="xMidYMid meet"');
  }
  return normalized;
};

let diagramContent = '';

if (fs.existsSync(cacheFile)) {
  if (format === 'svg') {
    diagramContent = normalizeSvg(fs.readFileSync(cacheFile, 'utf-8'));
  } else {
    const encoded = fs.readFileSync(cacheFile).toString('base64');
    diagramContent = `<img src="data:image/png;base64,${encoded}" alt="Python generated diagram" />`;
  }
} else {
  try {
    fs.mkdirSync(workDir, { recursive: true });
    const scriptFile = path.join(workDir, 'diagram.py');
    const outputFile = path.join(workDir, `diagram.${format}`);
    const wrappedCode = `${processedCode}

import os as _libreuni_os
if not _libreuni_os.path.exists(_libreuni_os.environ["LIBREUNI_OUTPUT"]):
    try:
        import matplotlib.pyplot as _libreuni_plt
        if _libreuni_plt.get_fignums():
            _libreuni_plt.savefig(_libreuni_os.environ["LIBREUNI_OUTPUT"], bbox_inches="tight", dpi=180, transparent=True)
    except Exception:
        pass
`;

    fs.writeFileSync(scriptFile, wrappedCode);
    execFileSync('python3', [scriptFile], {
      cwd: workDir,
      encoding: 'utf-8',
      env: {
        ...process.env,
        MPLBACKEND: 'Agg',
        LIBREUNI_OUTPUT: outputFile,
      },
      maxBuffer: 10 * 1024 * 1024,
    });

    if (!fs.existsSync(outputFile)) {
      throw new Error(`Python diagram did not create ${outputFile}. Save to os.environ["LIBREUNI_OUTPUT"].`);
    }

    fs.copyFileSync(outputFile, cacheFile);

    if (format === 'svg') {
      diagramContent = normalizeSvg(fs.readFileSync(cacheFile, 'utf-8'));
      fs.writeFileSync(cacheFile, diagramContent);
    } else {
      const encoded = fs.readFileSync(cacheFile).toString('base64');
      diagramContent = `<img src="data:image/png;base64,${encoded}" alt="Python generated diagram" />`;
    }
  } catch (e: any) {
    const pageUrl = Astro.url.pathname;
    const errorMsg = `\n[${new Date().toISOString()}] PAGE: ${pageUrl}\nHASH: ${hash}\nERROR: ${e.message}\nCODE:\n${processedCode}\n----------------------------------------\n`;
    fs.appendFileSync(ERROR_LOG, errorMsg);

    diagramContent = `
      <div class="w-full text-center py-10 bg-rose-50/50 dark:bg-rose-900/10 rounded-3xl border border-rose-200 dark:border-rose-900/30">
        <div class="inline-flex p-3 bg-rose-100 dark:bg-rose-900/40 text-rose-600 dark:text-rose-400 rounded-2xl mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h4 class="font-black text-rose-900 dark:text-rose-100 uppercase tracking-tighter text-sm mb-1">Python Diagram Error</h4>
        <p class="text-[10px] font-bold text-rose-400/80 uppercase tracking-widest leading-relaxed px-4">The Python diagram failed during build.</p>
        <div class="mt-8 mx-auto max-w-[90%] text-left">
          <div class="text-[9px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em] opacity-50 mb-2 px-4">Source Definition</div>
          <pre class="bg-white/50 dark:bg-black/20 p-6 rounded-2xl border border-rose-100 dark:border-rose-900/20 font-mono text-xs overflow-x-auto text-light-text dark:text-dark-text opacity-70">${escapeHtml(processedCode)}</pre>
        </div>
      </div>
    `;
  }
}
---

<div class:list={['diagram-frame python-diagram-frame my-12 flex flex-col items-center bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-[2rem] shadow-xl p-6 md:p-8 transition-colors w-full max-w-5xl mx-auto', { 'book-only-diagram': bookOnly, 'book-only': bookOnly }]} data-diagram-kind="Python">
  <div class="diagram-toolbar">
    <details class="diagram-source group/source">
      <summary class="diagram-source-summary" aria-label="Show Python source">Code</summary>
      <div class="diagram-source-code group/code">
         <button type="button" class="diagram-copy-button absolute top-3 right-3 px-2 py-1 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-[10px] font-bold uppercase tracking-wider opacity-0 group-hover/code:opacity-100 transition-opacity z-10 hover:bg-slate-200 dark:hover:bg-slate-700 shadow-sm text-slate-700 dark:text-slate-300" aria-label="Copy code" data-code={processedCode}>Copy</button>
         <pre class="m-0 p-4 max-h-[min(28rem,60vh)] overflow-auto text-[0.78rem] leading-[1.55] rounded-[1rem]"><code set:html={highlightedCode}></code></pre>
      </div>
    </details>
  </div>
  <div class="diagram-render w-full flex justify-center dark:invert dark:hue-rotate-180 dark:brightness-110">
    <Fragment set:html={diagramContent} />
  </div>
  <div class="diagram-source-title">{title}</div>
</div>
