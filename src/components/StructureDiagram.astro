---
interface Props {
  kind: 'array' | 'list' | 'stack' | 'queue' | 'tree' | 'invalid-tree' | 'rotation' | 'heap' | 'graph' | 'hash' | 'trie' | 'btree' | 'union-find' | 'versions' | 'lsm' | 'timeline' | 'sort';
  title: string;
  caption: string;
  variant?: string;
}

const { kind, title, caption, variant = 'default' } = Astro.props;
const palette = {
  stroke: '#334155',
  node: '#dbeafe',
  accent: '#10b981',
  warning: '#fecaca',
  text: '#0f172a',
};

const box = (x: number, y: number, label: string, fill = palette.node, width = 72) => ({ x, y, label, fill, width });
const arrayValues = variant === 'capacity' ? ['4', '7', '2', '10', '·', '·', '·', '·'] : ['4', '7', '2', '10'];
const treeValues = variant === 'degenerate' ? ['8', '3', '1', '0'] : ['8', '3', '10', '1', '6', '14'];
---

<figure class="structure-diagram my-10 overflow-x-auto rounded-2xl border border-light-border bg-light-surface p-4 shadow-sm dark:border-dark-border dark:bg-dark-surface" data-structure-diagram data-structure-kind={kind} data-structure-variant={variant}>
  <figcaption class="mb-3 text-sm font-bold text-light-text dark:text-dark-text">{title}</figcaption>
  <svg viewBox="0 0 720 230" role="img" aria-label={caption} class="mx-auto block min-w-[34rem] max-w-4xl">
    {kind === 'array' && (
      <g>
        {arrayValues.map((value, index) => <g><rect x={55 + index * 76} y="78" width="68" height="52" rx="8" fill={index < 4 ? palette.accent : '#e2e8f0'} fill-opacity={index < 4 ? '0.22' : '0.7'} stroke={palette.stroke} /><text x={89 + index * 76} y="109" text-anchor="middle" fill={palette.text} font-size="20">{value}</text><text x={89 + index * 76} y="151" text-anchor="middle" fill={palette.stroke} font-size="12">{index}</text></g>)}
        <path d="M55 55H359" stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" /><text x="55" y="42" fill={palette.text} font-size="15">logical prefix →</text>
      </g>
    )}
    {kind === 'list' && (
      <g>
        {['head', '12', '27', '41', 'null'].map((value, index) => <g><rect x={35 + index * 130} y="82" width="88" height="52" rx="10" fill={value === 'null' ? '#f1f5f9' : palette.node} stroke={palette.stroke} /><text x={79 + index * 130} y="114" text-anchor="middle" fill={palette.text} font-size="18">{value}</text>{index < 4 && <path d={`M123 ${108}H${164 + index * 130}`} stroke={palette.stroke} stroke-width="3" marker-end="url(#arrow)" />}</g>)}
        <text x="35" y="62" fill={palette.accent} font-size="15">next pointers</text>
      </g>
    )}
    {kind === 'stack' && (
      <g>
        {[['top', '#bbf7d0'], ['B', palette.node], ['A', palette.node]].map(([value, fill], index) => <g><rect x="275" y={35 + index * 55} width="120" height="42" rx="8" fill={fill} stroke={palette.stroke} /><text x="335" y={62 + index * 55} text-anchor="middle" fill={palette.text} font-size="18">{value}</text></g>)}
        <path d="M440 58h100" stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" /><text x="445" y="45" fill={palette.text} font-size="15">push/pop here</text>
      </g>
    )}
    {kind === 'queue' && (
      <g>
        {[['head', '#bbf7d0'], ['A', palette.node], ['B', palette.node], ['tail', '#fed7aa']].map(([value, fill], index) => <g><rect x={110 + index * 125} y="90" width="92" height="45" rx="8" fill={fill} stroke={palette.stroke} /><text x={156 + index * 125} y="118" text-anchor="middle" fill={palette.text} font-size="17">{value}</text>{index < 3 && <path d={`M203 ${112}H${226 + index * 125}`} stroke={palette.stroke} stroke-width="3" marker-end="url(#arrow)" />}</g>)}
        <text x="110" y="75" fill={palette.text} font-size="15">dequeue →</text><text x="452" y="75" fill={palette.text} font-size="15">← enqueue</text>
      </g>
    )}
    {(kind === 'tree' || kind === 'invalid-tree') && (
      <g>
        <path d="M360 57L235 105M360 57L485 105M235 127L170 178M235 127L300 178M485 127L550 178" stroke={palette.stroke} stroke-width="3" fill="none" />
        {[box(328, 35, treeValues[0], kind === 'invalid-tree' ? palette.warning : '#bbf7d0'), box(203, 105, treeValues[1]), box(453, 105, treeValues[2]), box(138, 178, treeValues[3]), box(268, 178, treeValues[4]), box(518, 178, treeValues[5])].map((node) => <g><circle cx={node.x + 36} cy={node.y} r="25" fill={node.fill} stroke={palette.stroke} stroke-width="3" /><text x={node.x + 36} y={node.y + 7} text-anchor="middle" fill={palette.text} font-size="18">{node.label}</text></g>)}
        {kind === 'invalid-tree' && <text x="360" y="218" text-anchor="middle" fill="#b91c1c" font-size="15">ancestor bound violated</text>}
      </g>
    )}
    {kind === 'rotation' && (
      <g>
        <text x="175" y="25" text-anchor="middle" fill={palette.text} font-size="16">before</text><text x="545" y="25" text-anchor="middle" fill={palette.text} font-size="16">after</text>
        <path d="M175 58L115 115M175 58L235 115M545 58L485 115M545 58L605 115" stroke={palette.stroke} stroke-width="3" />
        {[{x:150,y:58,t:'y'},{x:90,y:115,t:'x'},{x:210,y:115,t:'C'},{x:520,y:58,t:'x'},{x:460,y:115,t:'A'},{x:580,y:115,t:'y'}].map((n) => <g><circle cx={n.x} cy={n.y} r="26" fill={n.t === 'x' ? '#bbf7d0' : palette.node} stroke={palette.stroke} stroke-width="3" /><text x={n.x} y={n.y + 7} text-anchor="middle" fill={palette.text} font-size="18">{n.t}</text></g>)}
        <path d="M315 100h90" stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" /><text x="360" y="86" text-anchor="middle" fill={palette.accent} font-size="14">right rotation</text>
      </g>
    )}
    {kind === 'heap' && (
      <g>
        <path d="M360 57L240 110M360 57L480 110M240 132L180 185M240 132L300 185M480 132L540 185" stroke={palette.stroke} stroke-width="3" />
        {[['3',360,57,'#bbf7d0'],['8',240,110,palette.node],['5',480,110,palette.node],['14',180,185,palette.node],['11',300,185,palette.node]].map(([t,x,y,fill]) => <g><circle cx={x} cy={y} r="26" fill={fill} stroke={palette.stroke} stroke-width="3" /><text x={x} y={Number(y) + 7} text-anchor="middle" fill={palette.text} font-size="18">{t}</text></g>)}
        <text x="360" y="220" text-anchor="middle" fill={palette.text} font-size="14">parent priority ≤ child priority</text>
      </g>
    )}
    {kind === 'graph' && (
      <g>
        <path d="M160 80L350 48L525 95L430 180L205 175L160 80M350 48L430 180M205 175L525 95" stroke={palette.stroke} stroke-width="4" fill="none" />
        {[['A',160,80],['B',350,48],['C',525,95],['D',430,180],['E',205,175]].map(([t,x,y], index) => <g><circle cx={x} cy={y} r="27" fill={index === 0 ? '#bbf7d0' : palette.node} stroke={palette.stroke} stroke-width="3" /><text x={x} y={Number(y) + 7} text-anchor="middle" fill={palette.text} font-size="18">{t}</text></g>)}
      </g>
    )}
    {kind === 'hash' && (
      <g>
        {['∅', '18', '25', 'T', '32', '∅', '46'].map((value, index) => <g><rect x={65 + index * 88} y="82" width="72" height="56" rx="8" fill={value === 'T' ? '#fed7aa' : value === '∅' ? '#f1f5f9' : palette.node} stroke={palette.stroke} /><text x={101 + index * 88} y="114" text-anchor="middle" fill={palette.text} font-size="18">{value}</text><text x={101 + index * 88} y="158" text-anchor="middle" fill={palette.stroke} font-size="12">{index}</text></g>)}
        <path d="M101 48H365" stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" /><text x="101" y="35" fill={palette.text} font-size="15">probe sequence h(k), h(k)+1, …</text>
      </g>
    )}
    {kind === 'trie' && (
      <g>
        <path d="M360 48L270 105M360 48L450 105M270 127L205 180M270 127L335 180M450 127L515 180" stroke={palette.stroke} stroke-width="3" />
        {[['∅',360,48],['t',270,105],['e',450,105],['a',205,180],['n',335,180],['r',515,180]].map(([t,x,y], index) => <g><circle cx={x} cy={y} r="25" fill={index > 2 ? '#bbf7d0' : palette.node} stroke={palette.stroke} stroke-width="3" /><text x={x} y={Number(y) + 7} text-anchor="middle" fill={palette.text} font-size="18">{t}</text></g>)}
        <text x="360" y="220" text-anchor="middle" fill={palette.text} font-size="14">terminal markers distinguish tea from prefix te</text>
      </g>
    )}
    {kind === 'btree' && (
      <g>
        <path d="M360 75L180 150M360 75L360 150M360 75L540 150" stroke={palette.stroke} stroke-width="3" />
        <rect x="275" y="35" width="170" height="45" rx="8" fill="#bbf7d0" stroke={palette.stroke} stroke-width="3" /><text x="360" y="64" text-anchor="middle" fill={palette.text} font-size="17">[30 | 60]</text>
        {[['[5|18|24]',95],['[35|48]',275],['[72|90]',455]].map(([t,x]) => <g><rect x={x} y="150" width="170" height="45" rx="8" fill={palette.node} stroke={palette.stroke} stroke-width="3" /><text x={Number(x) + 85} y="179" text-anchor="middle" fill={palette.text} font-size="16">{t}</text></g>)}
        <path d="M95 210H625" stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" /><text x="360" y="228" text-anchor="middle" fill={palette.text} font-size="14">linked leaves support range scans</text>
      </g>
    )}
    {kind === 'union-find' && (
      <g>
        <path d="M360 55L270 115M360 55L450 115M270 137L210 185M270 137L330 185" stroke={palette.stroke} stroke-width="3" />
        {[['0',360,55],['1',270,115],['2',450,115],['3',210,185],['4',330,185]].map(([t,x,y], index) => <g><circle cx={x} cy={y} r="24" fill={index === 0 ? '#bbf7d0' : palette.node} stroke={palette.stroke} stroke-width="3" /><text x={x} y={Number(y) + 6} text-anchor="middle" fill={palette.text} font-size="17">{t}</text></g>)}
        <path d="M500 75h120" stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" /><text x="500" y="62" fill={palette.text} font-size="14">find(3) → root 0</text>
      </g>
    )}
    {kind === 'versions' && (
      <g>
        <path d="M170 75L350 75L530 75M350 75L350 160" stroke={palette.stroke} stroke-width="3" marker-end="url(#arrow)" />
        {[['v0',170,75],['v1',350,75],['v2',530,75],['shared',350,160]].map(([t,x,y], index) => <g><circle cx={x} cy={y} r="34" fill={index === 3 ? '#fde68a' : palette.node} stroke={palette.stroke} stroke-width="3" /><text x={x} y={Number(y) + 6} text-anchor="middle" fill={palette.text} font-size="16">{t}</text></g>)}
        <text x="360" y="215" text-anchor="middle" fill={palette.text} font-size="14">old roots remain readable; unchanged subtrees are shared</text>
      </g>
    )}
    {kind === 'lsm' && (
      <g>
        {[['memtable',70,'#bbf7d0'],['L0',245,palette.node],['L1',420,'#ddd6fe']].map(([t,x,fill]) => <g><rect x={x} y="80" width="160" height="62" rx="10" fill={fill} stroke={palette.stroke} stroke-width="3" /><text x={Number(x) + 80} y="107" text-anchor="middle" fill={palette.text} font-size="16">{t}</text><text x={Number(x) + 80} y="130" text-anchor="middle" fill={palette.text} font-size="14">a:1 · c:3</text></g>)}
        <path d="M230 111H240M405 111H415" stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" /><text x="360" y="185" text-anchor="middle" fill={palette.text} font-size="15">flush → sorted run → compact</text>
      </g>
    )}
    {kind === 'timeline' && (
      <g>
        <path d="M85 125H635" stroke={palette.stroke} stroke-width="4" marker-end="url(#arrow)" />
        {[['add e',130],['query',270],['delete e',410],['query',550]].map(([t,x], index) => <g><circle cx={x} cy="125" r="18" fill={index === 1 || index === 3 ? '#bbf7d0' : palette.node} stroke={palette.stroke} stroke-width="3" /><text x={x} y="92" text-anchor="middle" fill={palette.text} font-size="15">{t}</text><text x={x} y="165" text-anchor="middle" fill={palette.stroke} font-size="13">t{index}</text></g>)}
      </g>
    )}
    {kind === 'sort' && (
      <g>
        {[['unsorted',70,['7','2','5','1']],['partition',285,['1','2','5','7']],['sorted',500,['1','2','5','7']]].map(([label,x,values]) => <g><text x={Number(x) + 75} y="38" text-anchor="middle" fill={palette.text} font-size="15">{label}</text>{values.map((value, index) => <rect x={Number(x) + index * 38} y="75" width="32" height="44" rx="5" fill={label === 'sorted' ? '#bbf7d0' : palette.node} stroke={palette.stroke} /><text x={Number(x) + 16 + index * 38} y="103" text-anchor="middle" fill={palette.text} font-size="16">{value}</text>)}{label !== 'sorted' && <path d={`M${Number(x) + 170} 97H${Number(x) + 195}`} stroke={palette.accent} stroke-width="4" marker-end="url(#arrow)" />}</g>)}
      </g>
    )}
    <defs><marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill={palette.stroke} /></marker></defs>
  </svg>
  <p class="mt-3 text-center text-sm text-light-muted dark:text-dark-muted">{caption}</p>
</figure>
