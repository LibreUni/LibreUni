---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  className?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { href, variant = 'primary', className = '', size = 'md' } = Astro.props;

const variants = {
  primary: 'btn-primary',
  secondary: 'btn-secondary',
  ghost: 'bg-transparent hover:bg-light-accent/10 dark:hover:bg-dark-accent/10 text-light-text dark:text-dark-text'
};

const sizes = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-8 py-4 text-sm',
  lg: 'px-10 py-6 text-lg'
};
---

<a 
  href={href} 
  class:list={[
    'btn-base',
    variants[variant],
    sizes[size],
    className
  ]}
>
  <slot />
</a>
