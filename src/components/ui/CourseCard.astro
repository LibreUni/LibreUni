---
interface Props {
  id: string;
  title: string;
  description: string;
  icon: any;
  color: string;
  count: number;
}

const { id, title, description, icon: Icon, color, count } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<a href={`${baseUrl}courses/${id}`} class="group relative card-surface p-8 overflow-hidden flex flex-col h-full !rounded-3xl">
  {/* Decorative background gradient */}
  <div class:list={["absolute inset-0 opacity-0 group-hover:opacity-10 dark:group-hover:opacity-20 transition-opacity duration-500 bg-gradient-to-br", color]}></div>
  
  <div class="relative z-10">
      <div class:list={["w-16 h-16 rounded-3xl flex items-center justify-center mb-8 shadow-xl transform group-hover:rotate-12 transition-all duration-500", color, "text-white"]}>
          <Icon size={32} strokeWidth={2.5} />
      </div>
      
      <div class="space-y-4">
          <div class="flex items-center gap-3">
              <span class="label-caps !text-primary bg-primary/10 px-3 py-1 rounded-xl">Course</span>
              <span class="label-caps">{count} Lessons</span>
          </div>
          <h3 class="text-3xl font-[900] text-light-text dark:text-dark-text tracking-tighter leading-tight">{title}</h3>
          <p class="text-light-muted dark:text-dark-muted font-medium line-clamp-3 leading-relaxed">
              {description}
          </p>
      </div>
  </div>

  <div class="mt-auto pt-8 flex items-center justify-between relative z-10">
      <span class="font-black text-xs uppercase tracking-[0.2em] group-hover:text-primary transition-colors">Start Track</span>
      <div class="w-10 h-10 rounded-2xl border border-light-border dark:border-dark-border flex items-center justify-center group-hover:bg-primary group-hover:border-primary group-hover:text-white transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transform -rotate-45 group-hover:rotate-0 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>
  </div>
</a>
