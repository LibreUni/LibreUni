---
import { Maximize2, Minimize2 } from 'lucide-react';

interface Props {
  courseTitle: string;
  courseId: string;
  module: string;
  title: string;
}

const { courseTitle, courseId, module, title } = Astro.props;
---

<header class="mb-12 md:mb-16">
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2">
            <a href={`${import.meta.env.BASE_URL}courses/${courseId}`} class="label-caps !text-primary hover:opacity-80 transition-opacity">
                {courseTitle}
            </a>
            <span class="text-light-muted dark:text-dark-muted">/</span>
            <span class="label-caps">{module}</span>
        </div>
        
        <button 
            id="view-toggle"
            class="hidden md:flex p-2 rounded-xl bg-light-accent/5 dark:bg-dark-accent/5 border border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:text-light-text dark:hover:text-dark-text transition-all hover:bg-light-accent/10 dark:hover:bg-dark-accent/10"
            title="Toggle Expanded View"
        >
            <span id="max-icon"><Maximize2 size={16} /></span>
            <span id="min-icon" class="hidden"><Minimize2 size={16} /></span>
        </button>
    </div>
    <h1 class="heading-hero">{title}</h1>
    <div class="h-1.5 w-16 md:w-20 bg-primary rounded-full"></div>
</header>
