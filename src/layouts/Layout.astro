            </div>

            <div class="space-y-4">
                <p class="text-[10px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em]">Search Knowledge</p>
                <Search client:load baseUrl={import.meta.env.BASE_URL} />
            </div>

            <div class="mt-auto py-12 text-center">
                <p class="text-[10px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em] opacity-40">© 2026 LIBREUNI PROJECT</p>
            </div>
        </div>
    </div>

    <!-- Mobile Sidebar Backdrop (for lessons) -->
    <div id="sidebar-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[45] hidden transition-opacity opacity-0"></div>

    <div class="flex min-h-screen relative pt-16">
      <slot />
    </div>

    <div id="diagram-overlay" class="diagram-overlay" aria-hidden="true">
      <button type="button" class="diagram-overlay-close" aria-label="Close diagram">Close</button>
      <div class="diagram-overlay-panel" role="dialog" aria-modal="true" aria-label="Expanded diagram">
        <div id="diagram-overlay-content" class="diagram-overlay-content"></div>
      </div>
    </div>

    <script is:inline>
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');

        menuToggle?.addEventListener('click', () => {
            const isOpen = !mobileMenu.classList.contains('translate-x-full');
            if (isOpen) {
                mobileMenu.classList.add('translate-x-full');
                mobileMenu.classList.add('pointer-events-none');
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
                document.body.style.overflow = '';
            } else {
                mobileMenu.classList.remove('translate-x-full');
                mobileMenu.classList.remove('pointer-events-none');
                menuIcon.classList.add('hidden');
                closeIcon.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }
        });

        // Close menu on link clicks
        mobileMenu?.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('translate-x-full');
                mobileMenu.classList.add('pointer-events-none');
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
                document.body.style.overflow = '';
            });
        });

        const diagramOverlay = document.getElementById('diagram-overlay');
        const diagramOverlayContent = document.getElementById('diagram-overlay-content');
        const diagramOverlayClose = diagramOverlay?.querySelector('.diagram-overlay-close');
        let diagramPreviousFocus = null;

        function closeDiagramOverlay() {
            if (!diagramOverlay || !diagramOverlayContent) return;
            diagramOverlay.classList.remove('is-open');
            diagramOverlay.setAttribute('aria-hidden', 'true');
            diagramOverlayContent.replaceChildren();
            document.body.style.overflow = '';
            if (diagramPreviousFocus && typeof diagramPreviousFocus.focus === 'function') {
                diagramPreviousFocus.focus();
            }
        }

        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            if (target.closest('.diagram-source')) return;

            const frame = target.closest('.diagram-frame');
            if (frame && !target.closest('a') && !target.closest('.diagram-overlay')) {
                const render = frame.querySelector('.diagram-render');
                if (!render || !diagramOverlay || !diagramOverlayContent) return;
                diagramPreviousFocus = document.activeElement;
                diagramOverlayContent.replaceChildren(render.cloneNode(true));
                diagramOverlay.classList.add('is-open');
                diagramOverlay.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
                diagramOverlayClose?.focus();
            }
        });

        diagramOverlayClose?.addEventListener('click', closeDiagramOverlay);
        diagramOverlay?.addEventListener('click', (event) => {
            if (event.target === diagramOverlay) closeDiagramOverlay();
        });
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && diagramOverlay?.classList.contains('is-open')) {
                closeDiagramOverlay();
            }
        });

        // Copy button generic logic
        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const copyBtn = target.closest('.diagram-copy-button');
            if (copyBtn) {
                const code = copyBtn.getAttribute('data-code');
                if (code) {
                    navigator.clipboard.writeText(code);
                    const originalText = copyBtn.innerHTML;
                    copyBtn.innerHTML = 'Copied!';
                    setTimeout(() => copyBtn.innerHTML = originalText, 2000);
                }
                return;
            }

            // Zoom logic for rendered diagram overlay
            const diagramRender = target.closest('.diagram-overlay-content .diagram-render');
            if (diagramRender) {
                diagramRender.classList.toggle('zoomed');
            }
        });
    </script>

    <script>  const KEY = 'lu:dev-theme';
  const CATS = [
    { label:'Brand', vars:[{k:'--primary-rgb',l:'Primary'},{k:'--secondary-rgb',l:'Secondary'},{k:'--accent-rgb',l:'Accent'}] },
    { label:'Light', vars:[{k:'--light-bg-rgb',l:'BG'},{k:'--light-surface-rgb',l:'Surface'},{k:'--light-border-rgb',l:'Border'},{k:'--light-text-rgb',l:'Text'},{k:'--light-muted-rgb',l:'Muted'},{k:'--light-accent-rgb',l:'Accent'}] },
    { label:'Dark', vars:[{k:'--dark-bg-rgb',l:'BG'},{k:'--dark-surface-rgb',l:'Surface'},{k:'--dark-border-rgb',l:'Border'},{k:'--dark-text-rgb',l:'Text'},{k:'--dark-muted-rgb',l:'Muted'},{k:'--dark-accent-rgb',l:'Accent'}] },
  ];
  const FONTS = ['Plus Jakarta Sans','Literata','Space Grotesk'];

  function load() { try{return JSON.parse(localStorage.getItem(KEY))||{}}catch{return{}} }
  function read(k) {
    let o = load();
    if (o[k]) return o[k];
    return getComputedStyle(document.documentElement).getPropertyValue(k).trim();
  }
  function write(k, v) {
    let o = load();
    o[k] = v;
    localStorage.setItem(KEY, JSON.stringify(o));
    applyStyles();
  }
  function rgb2h(s) { let p=s.split(' ').map(Number); return '#'+p.map(v=>v.toString(16).padStart(2,'0')).join(''); }
  function h2r(h) { let m=/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(h); return m?`${parseInt(m[1],16)} ${parseInt(m[2],16)} ${parseInt(m[3],16)}`:null; }

  function applyStyles() {
    let styleEl = document.getElementById('lu-dev-themer-styles');
    if (!styleEl) {
      styleEl = document.createElement('style');
      styleEl.id = 'lu-dev-themer-styles';
      document.head.appendChild(styleEl);
    }
    const o = load();
    const curT = document.documentElement.dataset.theme || 'monochrome';
    const lightVars = [];
    const darkVars = [];
    const globalVars = [];
    
    Object.keys(o).forEach(k => {
      const val = o[k];
      if (k === '--font-sans') {
        globalVars.push(`${k}: ${val};`);
      } else if (k.startsWith('--light-')) {
        lightVars.push(`${k}: ${val};`);
        if (k.endsWith('-rgb')) {
          try { lightVars.push(`${k.slice(0, -4)}: ${rgb2h(val)};`); } catch(e){}
        }
      } else if (k.startsWith('--dark-')) {
        darkVars.push(`${k}: ${val};`);
        if (k.endsWith('-rgb')) {
          try { darkVars.push(`${k.slice(0, -4)}: ${rgb2h(val)};`); } catch(e){}
        }
      } else {
        globalVars.push(`${k}: ${val};`);
        if (k.endsWith('-rgb')) {
          try { globalVars.push(`${k.slice(0, -4)}: ${rgb2h(val)};`); } catch(e){}
        }
      }
    });

    let css = '';
    const lightSelector = curT === 'modern' ? 'html[data-theme="modern"], :root' : `html[data-theme="${curT}"]`;
    const darkSelector = curT === 'modern' ? 'html.dark' : `html.dark[data-theme="${curT}"]`;
    const globalSelector = curT === 'modern' ? ':root' : `html[data-theme="${curT}"]`;

    if (globalVars.length) css += `${globalSelector} {\n  ${globalVars.join('\n  ')}\n}\n`;
    if (lightVars.length) css += `${lightSelector} {\n  ${lightVars.join('\n  ')}\n}\n`;
    if (darkVars.length) css += `${darkSelector} {\n  ${darkVars.join('\n  ')}\n}\n`;
    styleEl.textContent = css;
  }

  function restore() { applyStyles(); }

  function applyTheme(id) { document.documentElement.dataset.theme=id; localStorage.setItem('theme',id); applyStyles(); }
  function applyMode(id) { 
    document.documentElement.dataset.colorMode=id; 
    let h=new Date().getHours(); 
    let isDark=id==='dark'||(id==='auto'&&(h>=22||h<7)); 
    document.documentElement.classList.toggle('dark',isDark); 
    localStorage.setItem('color-mode',id);
    applyStyles();
  }

