                            <Users size={24} />
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xl font-black">About</span>
                            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">LibreUni's mission</span>
                        </div>
                    </a>
                    <a href={`${import.meta.env.BASE_URL}development`} class="flex items-center gap-4 p-6 bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-3xl group active:scale-95 transition-all">
                        <div class="p-3 bg-primary/10 rounded-2xl text-primary">
                            <Code2 size={24} />
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xl font-black">Development</span>
                            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">Quality reports and course metrics</span>
