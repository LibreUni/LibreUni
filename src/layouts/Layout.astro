                            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">Follow role-based curricula</span>
                        </div>
                    </a>
                    <a href={`${import.meta.env.BASE_URL}about`} class="flex items-center gap-4 p-6 bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border rounded-3xl group active:scale-95 transition-all">
