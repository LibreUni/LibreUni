    document.body.appendChild(c);
    document.getElementById('lut-btn').onclick = () => c.classList.toggle('open');

    let themesEl = document.getElementById('lut-themes');
    ['modern','scholar','monochrome'].forEach(t => {
      let b = document.createElement('button');
      b.textContent = t;
      b.onclick = () => { applyTheme(t); updateActive(); };
      themesEl.appendChild(b);
    });

    let modesEl = document.getElementById('lut-modes');
    ['light','dark','auto'].forEach(m => {
      let b = document.createElement('button');
      b.textContent = m;
      b.onclick = () => { applyMode(m); updateActive(); };
      modesEl.appendChild(b);
    });

    let colorsEl = document.getElementById('lut-colors');
    CATS.forEach(cat => {
      let h = document.createElement('div');
      h.className = 'lut-h';
      h.textContent = cat.label;
      colorsEl.appendChild(h);
      cat.vars.forEach(v => {
        let val = read(v.k);
        let hex = val ? rgb2h(val) : '#888888';
        let row = document.createElement('div');
        row.className = 'lut-row';
        row.setAttribute('data-var', v.k);
        let inp = document.createElement('input');
        inp.type = 'color';
        inp.value = hex;
        inp.oninput = () => {
          let rgb = h2r(inp.value);
          if (rgb) { write(v.k, rgb); row.querySelector('.lut-val').textContent = rgb; }
        };
        let lbl = document.createElement('label');
        lbl.textContent = v.l;
        let valEl = document.createElement('span');
        valEl.className = 'lut-val';
        valEl.textContent = val;
        row.appendChild(inp); row.appendChild(lbl); row.appendChild(valEl);
        colorsEl.appendChild(row);
      });
    });

    let fontEl = document.getElementById('lut-font');
    let curFont = read('--font-sans');
    FONTS.forEach(f => {
      let o = document.createElement('option');
      o.value = f; o.textContent = f;
      if (f === curFont) o.selected = true;
      fontEl.appendChild(o);
    });
    fontEl.onchange = () => { write('--font-sans', fontEl.value); };

    function updateActive() {
      let curT = document.documentElement.dataset.theme;
      let curM = document.documentElement.dataset.colorMode;
      themesEl.querySelectorAll('button').forEach(b => b.classList.toggle('active', b.textContent === curT));
      modesEl.querySelectorAll('button').forEach(b => b.classList.toggle('active', b.textContent === curM));
    }
    updateActive();

    // Automatically sync active highlights when the html theme/color-mode attributes change
    const themeAttrObserver = new MutationObserver(() => updateActive());
    themeAttrObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme', 'data-color-mode']
    });

    // Clean up the MutationObserver when the themer panel is removed from the DOM
    const cleanupObserver = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        for (const removedNode of mutation.removedNodes) {
          if (removedNode === c) {
            themeAttrObserver.disconnect();
            cleanupObserver.disconnect();
            return;
          }
        }
      }
    });
    cleanupObserver.observe(document.body, { childList: true });

    restore();

    let picking = false;
    let pickOverlay = null;
    let elemInfoEl = document.getElementById('lut-elem-info');

    function stopPicking() {
      picking = false;
      document.getElementById('lut-pick').classList.remove('picking');
      if (pickOverlay) { pickOverlay.remove(); pickOverlay = null; }
      document.removeEventListener('mousemove', onPickMove);
      document.removeEventListener('click', onPickClick, true);
    }

    function onPickMove(e) {
      if (pickOverlay) {
        pickOverlay.style.display = 'none';
      }
      let el = document.elementFromPoint(e.clientX, e.clientY);
      if (pickOverlay) {
        pickOverlay.style.display = 'block';
      } else {
        pickOverlay = document.createElement('div');
        pickOverlay.style.cssText = 'position:fixed;pointer-events:none;z-index:2147483646;border:2px solid #3b82f6;background:rgba(59,130,246,.08);transition:all .08s;border-radius:2px';
        document.body.appendChild(pickOverlay);
      }
      if (el && !el.closest('#lu-dev-themer') && el !== document.documentElement && el !== document.body) {
        let r = el.getBoundingClientRect();
        pickOverlay.style.left = r.left+'px'; pickOverlay.style.top = r.top+'px';
        pickOverlay.style.width = r.width+'px'; pickOverlay.style.height = r.height+'px';
      }
    }

    function onPickClick(e) {
      let el = e.target;
      if (el === pickOverlay) {
        pickOverlay.style.display = 'none';
        el = document.elementFromPoint(e.clientX, e.clientY);
        pickOverlay.style.display = 'block';
      }
      if (el && el.closest('#lu-dev-themer')) return;
      e.preventDefault(); e.stopPropagation();
      stopPicking();
      showElemInfo(el);
    }

    function getUsedThemeVars(targetEl) {
      const used = new Set();
      const varMap = {
        '--primary': '--primary-rgb',
        '--primary-rgb': '--primary-rgb',
        '--secondary': '--secondary-rgb',
        '--secondary-rgb': '--secondary-rgb',
        '--accent': '--accent-rgb',
        '--accent-rgb': '--accent-rgb',
        '--light-bg': '--light-bg-rgb',
        '--light-bg-rgb': '--light-bg-rgb',
        '--light-surface': '--light-surface-rgb',
        '--light-surface-rgb': '--light-surface-rgb',
        '--light-border': '--light-border-rgb',
        '--light-border-rgb': '--light-border-rgb',
        '--light-text': '--light-text-rgb',
        '--light-text-rgb': '--light-text-rgb',
        '--light-muted': '--light-muted-rgb',
        '--light-muted-rgb': '--light-muted-rgb',
        '--light-accent': '--light-accent-rgb',
        '--light-accent-rgb': '--light-accent-rgb',
        '--dark-bg': '--dark-bg-rgb',
        '--dark-bg-rgb': '--dark-bg-rgb',
        '--dark-surface': '--dark-surface-rgb',
        '--dark-surface-rgb': '--dark-surface-rgb',
        '--dark-border': '--dark-border-rgb',
        '--dark-border-rgb': '--dark-border-rgb',
        '--dark-text': '--dark-text-rgb',
        '--dark-text-rgb': '--dark-text-rgb',
        '--dark-muted': '--dark-muted-rgb',
        '--dark-muted-rgb': '--dark-muted-rgb',
        '--dark-accent': '--dark-accent-rgb',
        '--dark-accent-rgb': '--dark-accent-rgb'
      };
      
      let curr = targetEl;
      while (curr && curr !== document.documentElement) {
        // 1. Check inline style
        const inline = curr.getAttribute('style') || '';
        for (const v in varMap) {
          if (inline.includes(v)) {
            used.add(varMap[v]);
          }
        }
        
        // 2. Check classes
        const classes = Array.from(curr.classList);
        for (const cls of classes) {
          if (cls.includes('primary')) used.add('--primary-rgb');
          if (cls.includes('secondary')) used.add('--secondary-rgb');
          if (cls.includes('accent')) used.add('--accent-rgb');
          if (cls.includes('light-bg') || cls.includes('bg-white')) used.add('--light-bg-rgb');
          if (cls.includes('light-surface') || cls.includes('bg-slate-50')) used.add('--light-surface-rgb');
          if (cls.includes('light-border') || cls.includes('border-slate-200')) used.add('--light-border-rgb');
          if (cls.includes('light-text') || cls.includes('text-slate-900')) used.add('--light-text-rgb');
          if (cls.includes('light-muted') || cls.includes('text-slate-500')) used.add('--light-muted-rgb');
          if (cls.includes('dark-bg')) used.add('--dark-bg-rgb');
          if (cls.includes('dark-surface')) used.add('--dark-surface-rgb');
          if (cls.includes('dark-border')) used.add('--dark-border-rgb');
          if (cls.includes('dark-text')) used.add('--dark-text-rgb');
          if (cls.includes('dark-muted')) used.add('--dark-muted-rgb');
        }

        // 3. Check matched stylesheets
        try {
          for (const sheet of document.styleSheets) {
            try {
              if (!sheet.cssRules) continue;
            } catch (e) {
              continue;
            }
            for (const rule of sheet.cssRules) {
              if (rule.type === CSSRule.STYLE_RULE && rule.selectorText) {
                try {
                  if (curr.matches(rule.selectorText)) {
                    const css = rule.style.cssText;
                    for (const v in varMap) {
                      if (css.includes(v)) {
                        used.add(varMap[v]);
                      }
                    }
                  }
                } catch (e) {}
              }
            }
          }
        } catch (e) {}
        
        curr = curr.parentElement;
      }
      return Array.from(used);
    }

    function showElemInfo(el) {
      if (!elemInfoEl) return;
      let tag = el.tagName.toLowerCase();
      let id = el.id ? '#'+el.id : '';
      let cls = Array.from(el.classList).join('.');
      let sel = tag + (id || (cls ? '.'+cls : ''));
      let rect = el.getBoundingClientRect();
      let font = getComputedStyle(el).fontFamily.split(',')[0].replace(/['"]/g,'').trim();

      let cs = getComputedStyle(el);
      let vars = [];
      for (let i = 0; i < cs.length; i++) {
        let name = cs[i];
        if (name.startsWith('--')) {
          let val = cs.getPropertyValue(name).trim();
          if (val) vars.push({k:name,v:val});
        }
      }

      // Clear previous highlights and badges on the rows
      document.querySelectorAll('#lu-dev-themer .lut-row').forEach(row => {
        row.classList.remove('highlighted');
        const badge = row.querySelector('.lut-used-badge');
        if (badge) badge.remove();
      });

      // Highlight matching rows
      const usedVars = getUsedThemeVars(el);
      usedVars.forEach(vKey => {
        const row = document.querySelector(`#lu-dev-themer .lut-row[data-var="${vKey}"]`);
        if (row) {
          row.classList.add('highlighted');
          let lbl = row.querySelector('label');
          if (lbl && !row.querySelector('.lut-used-badge')) {
            let badge = document.createElement('span');
            badge.className = 'lut-used-badge';
            badge.textContent = 'used';
            badge.style.cssText = 'font-size:9px;font-weight:900;text-transform:uppercase;background:#3b82f6;color:#fff;padding:1px 4px;border-radius:3px;margin-left:4px;vertical-align:middle;display:inline-block';
            lbl.appendChild(badge);
          }
        }
      });

      let html = '<div class="lut-elem"><div class="lut-elem-tag">'+sel.replace(/</g,'&lt;')+'</div>';
      html += '<div class="lut-elem-meta">📐 '+Math.round(rect.width)+' × '+Math.round(rect.height)+'px</div>';
      html += '<div class="lut-elem-meta">📝 '+font+'</div>';
      if (vars.length) {
        html += '<div class="lut-elem-section">CSS Variables ('+vars.length+')</div>';
        vars.forEach(v => { html += '<div class="lut-elem-var"><span class="lut-elem-var-k">'+v.k+'</span><span class="lut-elem-var-v">'+v.v+'</span></div>'; });
      }
      html += '</div>';
      elemInfoEl.innerHTML = html;
    }

    document.getElementById('lut-pick').onclick = () => {
      if (picking) { stopPicking(); return; }
      picking = true;
      document.getElementById('lut-pick').classList.add('picking');
      document.addEventListener('mousemove', onPickMove);
      document.addEventListener('click', onPickClick, true);
    };

    document.getElementById('lut-reset').onclick = () => {
      localStorage.removeItem(KEY);
      let styleEl = document.getElementById('lu-dev-themer-styles');
      if (styleEl) styleEl.remove();
      location.reload();
    };
    document.getElementById('lut-copy').onclick = () => {
      let curT = document.documentElement.dataset.theme;
      let curM = document.documentElement.dataset.colorMode;
      const isDark = curM === 'dark' || (curM === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
      
      let selector = ':root';
      if (curT && curT !== 'modern') {
        selector = isDark ? `html.dark[data-theme='${curT}']` : `html[data-theme='${curT}']`;
      } else if (curT === 'modern') {
        selector = isDark ? 'html.dark' : 'html[data-theme=\'modern\']';
      }

      let lines = [`${selector} {`];
      CATS.forEach(c => c.vars.forEach(v => {
        let val = read(v.k);
        if (val) {
          if (v.k.endsWith('-rgb')) {
            const hexKey = v.k.slice(0, -4);
            try {
              const hexVal = rgb2h(val);
              lines.push(`  ${hexKey}: ${hexVal};`);
            } catch (e) {}
          }
          lines.push(`  ${v.k}: ${val};`);
        }
      }));
      let f = read('--font-sans');
      if (f) lines.push(`  --font-sans: ${f};`);
      lines.push('}');
      navigator.clipboard.writeText(lines.join('\n'));
    };
  }

  function init() {
    const isEnabled = localStorage.getItem('lu:enable-dev-themer') === 'true';
    if (isEnabled) {
      make();
    } else {
      let existing = document.getElementById('lu-dev-themer');
      if (existing) existing.remove();
    }
  }

  restore();

  window.addEventListener('lu:toggle-dev-themer', init);
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
    </script>
  </body>
