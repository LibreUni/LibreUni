---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, BookOpen, Compass, GraduationCap, Github, GitBranch, Calendar } from 'lucide-react';
import { execSync } from 'child_process';

let commitHash = 'Unknown';
try {
  commitHash = execSync('git rev-parse --short HEAD').toString().trim();
} catch (e) {
  console.warn('Failed to retrieve commit hash:', e);
}

const buildTime = new Date().toUTCString();
---

<Layout title="About - LibreUni">
  <main class="flex-1 bg-light-bg dark:bg-dark-bg">
    <section class="border-b border-light-border bg-white px-6 py-16 dark:border-dark-border dark:bg-dark-bg md:px-8 md:py-24">
        <div class="mx-auto max-w-7xl">
            <p class="mb-4 text-xs font-black uppercase tracking-[0.25em] text-primary">About LibreUni</p>
            <h1 class="max-w-5xl text-5xl font-black uppercase leading-none tracking-tight text-light-text dark:text-dark-text md:text-7xl">
                Free university-level learning, built without distractions.
            </h1>
            <p class="mt-8 max-w-3xl text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                LibreUni exists to make rigorous education available without sign-in walls, ads, paywalls, or inflated ceremony. The project favors direct explanations, self-contained lessons, and interactive practice where it strengthens the idea being taught.
            </p>
        </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-16 md:px-8">
        <div class="grid gap-6 md:grid-cols-3">
            <div class="rounded-2xl border border-light-border bg-white p-8 dark:border-dark-border dark:bg-dark-surface">
                <div class="mb-8 inline-flex rounded-2xl bg-primary/10 p-4 text-primary">
                    <BookOpen size={28} strokeWidth={2.5} />
                </div>
                <h2 class="text-2xl font-black tracking-tight text-light-text dark:text-dark-text">Courses</h2>
                <p class="mt-4 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                    Tracks are designed as substantial bodies of study, not collections of disconnected tips.
                </p>
            </div>

            <div class="rounded-2xl border border-light-border bg-white p-8 dark:border-dark-border dark:bg-dark-surface">
                <div class="mb-8 inline-flex rounded-2xl bg-primary/10 p-4 text-primary">
                    <Compass size={28} strokeWidth={2.5} />
                </div>
                <h2 class="text-2xl font-black tracking-tight text-light-text dark:text-dark-text">Paths</h2>
                <p class="mt-4 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                    Career paths connect courses into role-oriented curricula for learners with concrete professional goals.
                </p>
            </div>

            <div class="rounded-2xl border border-light-border bg-white p-8 dark:border-dark-border dark:bg-dark-surface">
                <div class="mb-8 inline-flex rounded-2xl bg-primary/10 p-4 text-primary">
                    <GraduationCap size={28} strokeWidth={2.5} />
                </div>
                <h2 class="text-2xl font-black tracking-tight text-light-text dark:text-dark-text">Standards</h2>
                <p class="mt-4 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                    Lessons are expected to be self-contained, rigorous, and organized around theory, example, and exercise.
                </p>
            </div>
        </div>

        <div class="mt-16 grid gap-10 border-t border-light-border pt-16 dark:border-dark-border md:grid-cols-[1fr_1.4fr]">
            <div>
                <p class="mb-3 text-xs font-black uppercase tracking-[0.25em] text-primary">Principles</p>
                <h2 class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text md:text-5xl">The platform is intentionally plainspoken.</h2>
            </div>
            <div class="space-y-6 text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                <p>LibreUni avoids motivational filler and focuses on the substance of the topic. A lesson should define the concept, show how it behaves in practice, and give the learner a meaningful exercise.</p>
                <p>The interface follows the same idea: clean navigation, visible search, high contrast, and pages that separate courses, career paths, and project context clearly.</p>
                <div class="flex flex-col gap-4 pt-2 sm:flex-row">
                    <a href={`${import.meta.env.BASE_URL}courses`} class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-primary px-8 py-4 text-sm font-black uppercase tracking-widest text-white shadow-xl shadow-primary/20 transition-all hover:-translate-y-1">
                        Explore Courses
                        <ArrowRight size={18} className="transition-transform group-hover:translate-x-1" />
                    </a>
                    <a href={`${import.meta.env.BASE_URL}careers`} class="group inline-flex items-center justify-center gap-3 rounded-2xl border border-light-border bg-white px-8 py-4 text-sm font-black uppercase tracking-widest text-light-text transition-all hover:-translate-y-1 hover:border-primary hover:text-primary dark:border-dark-border dark:bg-dark-surface dark:text-dark-text">
                        View Paths
                        <Compass size={18} className="transition-transform group-hover:translate-x-1" />
                    </a>
                </div>
            </div>
        </div>

        <div class="mt-16 grid gap-10 border-t border-light-border pt-16 dark:border-dark-border md:grid-cols-[1fr_1.4fr]">
            <div>
                <p class="mb-3 text-xs font-black uppercase tracking-[0.25em] text-primary">Open Source</p>
                <h2 class="text-4xl font-black tracking-tight text-light-text dark:text-dark-text md:text-5xl">Built in the open for everyone.</h2>
            </div>
            <div class="space-y-6 text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                <p>LibreUni is completely open-source and community-driven. Everything you see—from the course curricula to the interactive learning components—is built and refined in public. We believe that the best education is collaborative, transparent, and free from proprietary constraints.</p>
                <p>Whether you want to write new lessons, design interactive widgets, correct a typo, or suggest new paths, your contributions are welcome. Join us in making rigorous, university-level education accessible to all.</p>
                <div class="flex flex-col gap-4 pt-2 sm:flex-row">
                    <a href="https://github.com/fredoslav2004/LibreUni" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-primary px-8 py-4 text-sm font-black uppercase tracking-widest text-white shadow-xl shadow-primary/20 transition-all hover:-translate-y-1">
                        Contribute on GitHub
                        <ArrowRight size={18} className="transition-transform group-hover:translate-x-1" />
                    </a>
                </div>

                <div class="mt-8 rounded-2xl border border-light-border bg-white p-6 dark:border-dark-border dark:bg-dark-surface max-w-2xl">
                    <h3 class="text-sm font-black uppercase tracking-[0.15em] text-light-text dark:text-dark-text mb-4 font-black">Deployment Metadata</h3>
                    <div class="grid gap-6 sm:grid-cols-2">
                        <div class="flex items-start gap-3">
                            <div class="mt-0.5 text-primary">
                                <GitBranch size={18} />
                            </div>
                            <div>
                                <p class="text-xs font-black uppercase tracking-wider text-light-muted dark:text-dark-muted">Commit Ref</p>
                                <p class="mt-1 font-mono text-sm font-bold text-light-text dark:text-dark-text">
                                    <a href={`https://github.com/fredoslav2004/LibreUni/commit/${commitHash}`} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline hover:text-primary/80 transition-colors">
                                        {commitHash}
                                    </a>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="mt-0.5 text-primary">
                                <Calendar size={18} />
                            </div>
                            <div>
                                <p class="text-xs font-black uppercase tracking-wider text-light-muted dark:text-dark-muted">Build Date</p>
                                <p class="mt-1 text-sm font-bold text-light-text dark:text-dark-text">{buildTime}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
  </main>
</Layout>
