---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getCourseLessons, type OrderedLesson } from '../../utils/lessons';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  const lessons = await getCollection('lessons');

  return Promise.all(courses.map(async (course) => ({
    params: { courseId: course.id },
    props: { course, lessons: await getCourseLessons(course.id, lessons) },
  })));
}

interface Props {
  course: CollectionEntry<'courses'>;
  lessons: OrderedLesson[];
}

const { course, lessons } = Astro.props;
const modules = lessons.reduce<{ title: string; lessons: OrderedLesson[] }[]>((groups, lesson) => {
  const title = lesson.data.module ?? 'Overview';
  const current = groups.at(-1);
  if (!current || current.title !== title) groups.push({ title, lessons: [] });
  groups.at(-1)!.lessons.push(lesson);
  return groups;
}, []);

const category = course.id.startsWith('math') ? 'Mathematics'
  : ['c', 'cpp', 'operating-systems', 'software-engineering', 'software-architecture', 'programming-languages'].includes(course.id) ? 'Computer Science'
  : course.id === 'machine-learning' ? 'AI & ML'
  : ['philosophy', 'philosophy-science'].includes(course.id) ? 'Philosophy'
  : ['devops', 'git', 'uml', 'python', 'javascript', 'libreuni', 'power-user'].includes(course.id) ? 'Development'
  : course.id === 'team-dynamics' ? 'Management'
  : 'General Studies';
const categoryClass = ({ Mathematics: 'math', 'Computer Science': 'cs', 'AI & ML': 'ai', Philosophy: 'phil', Development: 'dev', Management: 'mgmt' } as Record<string, string>)[category] ?? 'other';
const lessonSlugs = lessons.map((lesson) => lesson.slug);
const firstLesson = lessons[0];
---

<Layout title={`${course.data.title} - LibreUni`}>
  <main class="flex-1 bg-light-bg dark:bg-dark-bg">
    <section class="relative overflow-hidden border-b border-light-border bg-light-bg dark:border-dark-border dark:bg-dark-bg">
      <div class={`course-category-stripe course-category-${categoryClass} absolute inset-x-0 top-0 h-16`}></div>
      <div class="relative mx-auto max-w-7xl px-6 pb-12 pt-20 md:px-8 md:pb-16 md:pt-24">
        <p class="text-xs font-black uppercase tracking-[0.25em] text-white/90">{category}</p>
        <div class="mt-12 grid gap-10 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <h1 class="max-w-4xl text-5xl font-black leading-none tracking-tight text-light-text dark:text-dark-text md:text-7xl">{course.data.title}</h1>
            <p class="mt-6 max-w-3xl text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">{course.data.description}</p>
          </div>
          <div class="min-w-40 rounded-2xl border border-light-border bg-light-surface p-5 text-right dark:border-dark-border dark:bg-dark-surface">
            <p id="course-progress-value" class="text-4xl font-black tabular-nums text-light-text dark:text-dark-text">0%</p>
            <p class="mt-1 text-xs font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Course progress</p>
            <progress id="course-progress" class="course-progress mt-4 w-full" value="0" max="100">0%</progress>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-7xl gap-12 px-6 py-12 md:px-8 lg:grid-cols-[minmax(0,1fr)_18rem] lg:py-16">
      <div>
        <section aria-labelledby="prerequisites-heading" class="mb-12 rounded-2xl border border-primary/20 bg-primary/5 p-6 dark:border-primary/30 dark:bg-primary/10">
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Before you start</p>
              <h2 id="prerequisites-heading" class="mt-2 text-2xl font-black tracking-tight text-light-text dark:text-dark-text">Prerequisites</h2>
            </div>
            <p class="text-sm font-black text-light-text dark:text-dark-text">{course.data.ects} ECTS</p>
          </div>
          <div class="mt-5 grid gap-6 md:grid-cols-2">
            <div>
              <h3 class="text-xs font-black uppercase tracking-widest text-light-text dark:text-dark-text">Required</h3>
              <ul class="mt-2 list-disc space-y-2 pl-5 text-sm leading-relaxed text-light-muted dark:text-dark-muted">
                {course.data.prerequisites.required.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-black uppercase tracking-widest text-light-text dark:text-dark-text">Recommended</h3>
              <ul class="mt-2 list-disc space-y-2 pl-5 text-sm leading-relaxed text-light-muted dark:text-dark-muted">
                {course.data.prerequisites.recommended.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        </section>
        <section aria-labelledby="overview-heading">
          <p class="text-xs font-black uppercase tracking-[0.25em] text-primary">Course overview</p>
          <h2 id="overview-heading" class="mt-3 text-3xl font-black tracking-tight text-light-text dark:text-dark-text">Course outline</h2>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-light-muted dark:text-dark-muted">{course.data.overview ?? 'Follow the modules in order for a guided path, or open any lesson directly. Each module groups a connected set of concepts.'}</p>
        </section>

        <section class="mt-12" aria-labelledby="map-heading">
          <div class="flex items-baseline justify-between gap-4">
            <h2 id="map-heading" class="text-2xl font-black tracking-tight text-light-text dark:text-dark-text">Modules</h2>
            <span class="text-xs font-bold text-light-muted dark:text-dark-muted">{modules.length} modules · {lessons.length} lessons</span>
          </div>
          <ol class="mt-6 space-y-4">
            {modules.map((module, index) => (
              <li class="relative rounded-2xl border border-light-border bg-light-surface p-5 dark:border-dark-border dark:bg-dark-surface">
                {index < modules.length - 1 && <div class="absolute -bottom-5 left-8 h-5 border-l-2 border-light-border dark:border-dark-border" aria-hidden="true"></div>}
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="text-lg font-black text-light-text dark:text-dark-text"><span class="mr-3 text-primary">{String(index + 1).padStart(2, '0')}</span>{module.title}</h3>
                  <span class="text-xs font-bold text-light-muted dark:text-dark-muted">{module.lessons.length} lessons</span>
                </div>
                <ul class="mt-4 divide-y divide-light-border dark:divide-dark-border">
                  {module.lessons.map((lesson) => (
                    <li>
                      <a href={`${import.meta.env.BASE_URL}lessons/${lesson.slug}`} data-lesson-progress={lesson.slug} class="group flex min-h-12 items-center justify-between gap-4 py-3 text-sm font-bold text-light-text transition-colors hover:text-primary dark:text-dark-text">
                        <span>{lesson.data.title}</span>
                        <span class="lesson-complete hidden shrink-0 text-xs font-black uppercase tracking-wider text-emerald-600 dark:text-emerald-400">Complete</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ))}
          </ol>
        </section>
      </div>

      <aside class="h-fit rounded-2xl border border-light-border bg-light-surface p-6 dark:border-dark-border dark:bg-dark-surface lg:sticky lg:top-24">
        <div class="mb-6 flex items-center justify-between gap-4">
          <span class="text-xs font-black uppercase tracking-widest text-light-muted dark:text-dark-muted">Workload</span>
          <span class="text-2xl font-black tabular-nums text-light-text dark:text-dark-text">{course.data.ects} <span class="text-xs uppercase tracking-widest text-light-muted dark:text-dark-muted">ECTS</span></span>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-light-muted dark:text-dark-muted">Start learning</p>
        {firstLesson ? (
          <a id="resume-course" class="btn-primary mt-4 w-full !rounded-xl !px-5 !py-3 text-sm" href={`${import.meta.env.BASE_URL}lessons/${firstLesson.slug}`}>Start course</a>
        ) : <p class="mt-4 text-sm font-medium text-light-muted dark:text-dark-muted">Lessons are being prepared.</p>}
        <a class="btn-secondary mt-3 w-full !rounded-xl !px-5 !py-3 text-sm" href={`${import.meta.env.BASE_URL}courses/${course.id}.pdf`} target="_blank" rel="noopener" aria-label={`Open ${course.data.title} as a PDF`}>Open PDF</a>
      </aside>
    </section>
  </main>
</Layout>

<script is:inline define:vars={{ courseId: course.id, lessonSlugs, baseUrl: import.meta.env.BASE_URL }}>
  const refreshCourseProgress = () => {
    const completed = lessonSlugs.filter((slug) => localStorage.getItem(`completed-${slug}`) === 'true');
    const percentage = lessonSlugs.length ? Math.round((completed.length / lessonSlugs.length) * 100) : 0;
    const progress = document.getElementById('course-progress');
    const value = document.getElementById('course-progress-value');
    if (progress instanceof HTMLProgressElement) progress.value = percentage;
    if (value) value.textContent = `${percentage}%`;
    document.querySelectorAll('[data-lesson-progress]').forEach((link) => {
      const complete = localStorage.getItem(`completed-${link.getAttribute('data-lesson-progress')}`) === 'true';
      link.querySelector('.lesson-complete')?.classList.toggle('hidden', !complete);
    });
  };

  refreshCourseProgress();
  const lastVisited = localStorage.getItem(`last-visited-${courseId}`);
  if (lastVisited && lessonSlugs.includes(lastVisited)) {
    const resume = document.getElementById('resume-course');
    if (resume instanceof HTMLAnchorElement) {
      resume.href = `${baseUrl}lessons/${lastVisited}`;
      resume.textContent = 'Resume course';
    }
  }
  window.addEventListener('storage', (event) => {
    if (event.key?.startsWith('completed-')) refreshCourseProgress();
  });
</script>

<style>
  .course-progress { accent-color: rgb(var(--primary-rgb)); }
  .course-progress::-webkit-progress-bar { background: rgb(var(--light-border-rgb)); border-radius: 999px; }
  .course-progress::-webkit-progress-value { background: rgb(var(--primary-rgb)); border-radius: 999px; }
  :global(.dark) .course-progress::-webkit-progress-bar { background: rgb(var(--dark-border-rgb)); }
</style>
