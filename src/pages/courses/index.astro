---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ArrowRight } from 'lucide-react';

const courses = await getCollection('courses');
const lessons = await getCollection('lessons');
const publicCourseCount = courses.filter(course => course.data.status === 'public').length;
const draftCourseCount = courses.length - publicCourseCount;

const categoryLabels: Record<string, string> = {
    all: 'All categories',
    math: 'Mathematics',
    cs: 'Computer Science',
    ai: 'AI & ML',
    dev: 'Development',
    phil: 'Philosophy',
    mgmt: 'Management',
    other: 'Misc'
};

const stripeLabels: Record<string, string> = {
    all: 'General',
    math: 'Mathematics',
    cs: 'CS',
    ai: 'AI/ML',
    dev: 'Development',
    phil: 'Philosophy',
    mgmt: 'Management',
    other: 'General'
};

const getCategory = (courseId: string) => {
    if (courseId.startsWith('math')) return 'math';
    if (['c', 'cpp', 'operating-systems', 'software-engineering', 'software-architecture', 'programming-languages'].includes(courseId)) return 'cs';
    if (['machine-learning'].includes(courseId)) return 'ai';
    if (['philosophy', 'philosophy-science'].includes(courseId)) return 'phil';
    if (['devops', 'git', 'uml', 'python', 'javascript', 'libreuni', 'power-user'].includes(courseId)) return 'dev';
    if (['team-dynamics'].includes(courseId)) return 'mgmt';
    return 'other';
};

---

<Layout title="All Courses - LibreUni">
  <main class="flex-1 bg-light-bg dark:bg-dark-bg">
    <section class="border-b border-light-border bg-white px-6 py-12 dark:border-dark-border dark:bg-dark-bg md:px-8 md:py-16">
        <div class="mx-auto max-w-7xl">
            <p class="mb-4 text-xs font-black uppercase tracking-[0.25em] text-primary">All Courses</p>
            <div>
                <h1 class="text-4xl font-black leading-none tracking-tight text-light-text dark:text-dark-text md:text-6xl">Course catalog</h1>
                <p class="mt-5 max-w-3xl text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">
                    Complete university-level tracks for mathematics, computing, engineering practice, philosophy, and professional systems work.
                </p>
            </div>
        </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-12 md:px-8">
        <div class="sticky top-16 z-30 mb-8 rounded-2xl border border-light-border bg-white/95 p-4 shadow-xl shadow-slate-200/60 backdrop-blur dark:border-dark-border dark:bg-dark-surface/95 dark:shadow-black/20">
            <div class="grid gap-3 sm:grid-cols-[1fr_12rem_auto] sm:items-center">
                <label class="relative block">
                    <span class="sr-only">Search courses</span>
                    <svg class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-light-muted dark:text-dark-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input id="course-search" type="text" placeholder="Search courses" class="input-field pl-11 dark:text-white" />
                </label>

                <label class="block">
                    <span class="sr-only">Filter category</span>
                    <select id="category-filter" class="input-field cursor-pointer dark:text-white">
                        {Object.entries(categoryLabels).map(([value, label]) => (
                            <option value={value}>{label}</option>
                        ))}
                    </select>
                </label>

                <label class="block">
                    <span class="sr-only">Sort courses</span>
                    <select id="course-sort" class="input-field cursor-pointer dark:text-white">
                        <option value="title-asc">A to Z</option>
                        <option value="title-desc">Z to A</option>
                        <option value="modules-desc">Most modules</option>
                        <option value="modules-asc">Fewest modules</option>
                    </select>
                </label>

                <div class="text-right text-sm font-bold text-light-muted dark:text-dark-muted sm:col-start-3 sm:row-start-1">
                    <span id="course-count" class="text-light-text dark:text-dark-text">{publicCourseCount}</span> courses
                </div>
            </div>
            <label class="mt-3 inline-flex min-h-10 cursor-pointer items-center gap-2 text-xs font-bold text-light-muted dark:text-dark-muted">
                <input id="draft-toggle" type="checkbox" class="h-4 w-4 rounded border-light-border text-primary focus:ring-primary dark:border-dark-border" />
                Show drafts ({draftCourseCount})
            </label>
        </div>

        <div id="course-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {courses.map((course) => {
                const lessonCount = lessons.filter(lesson => lesson.data.course === course.id).length;
                const category = getCategory(course.id);

                return (
                    <article
                        class:list={['course-card group relative flex min-h-72 flex-col overflow-hidden rounded-2xl border border-light-border bg-white transition-all hover:-translate-y-1 hover:border-primary/50 hover:shadow-2xl hover:shadow-slate-200/70 dark:border-dark-border dark:bg-dark-surface dark:hover:shadow-black/30', { hidden: course.data.status === 'draft' }]}
                        data-category={category}
                        data-title={course.data.title.toLowerCase()}
                        data-modules={lessonCount}
                        data-visibility={course.data.status}
                    >
                        <div class={`course-category-stripe course-category-${category} pointer-events-none absolute inset-x-0 top-0 flex h-16 items-center gap-3 rounded-t-[calc(1rem-1px)] px-6`}>
                            <span class="text-[11px] font-black uppercase tracking-[0.16em] text-white">{stripeLabels[category]}</span>
                            <span class="border-l border-white/40 pl-3 text-[11px] font-bold text-white/90">{lessonCount} lessons</span>
                        </div>

                        <a href={`${import.meta.env.BASE_URL}courses/${course.id}`} class="relative flex flex-1 flex-col p-6 pt-24 focus:outline-none focus-visible:ring-4 focus-visible:ring-primary/20 rounded-2xl" aria-label={`Open ${course.data.title}`}>
                            <div class="mt-auto">
                                <h2 class="text-xl font-black tracking-tight text-light-text transition-colors group-hover:text-primary dark:text-dark-text">{course.data.title}</h2>
                                <p class="mt-3 line-clamp-3 text-sm font-medium leading-relaxed text-light-muted dark:text-dark-muted">{course.data.description}</p>

                                <div class="mt-8 flex items-center justify-between gap-2 text-xs font-black uppercase tracking-widest text-primary">
                                    <span>View course</span>
                                    <span class="text-light-muted dark:text-dark-muted">{course.data.ects} ECTS</span>
                                    <ArrowRight size={15} className="transition-transform group-hover:translate-x-1" />
                                </div>
                            </div>
                        </a>

                    </article>
                );
            })}
        </div>
    </section>
  </main>
</Layout>

<script is:inline>
    const cards = Array.from(document.querySelectorAll('.course-card'));
    const grid = document.getElementById('course-grid');
    const searchInput = document.getElementById('course-search');
    const categoryFilter = document.getElementById('category-filter');
    const sortSelect = document.getElementById('course-sort');
    const countLabel = document.getElementById('course-count');
    const draftToggle = document.getElementById('draft-toggle');

    const sorters = {
        'title-asc': (a, b) => a.dataset.title.localeCompare(b.dataset.title),
        'title-desc': (a, b) => b.dataset.title.localeCompare(a.dataset.title),
        'modules-desc': (a, b) => Number(b.dataset.modules) - Number(a.dataset.modules),
        'modules-asc': (a, b) => Number(a.dataset.modules) - Number(b.dataset.modules),
    };

    function updateCourses() {
        const query = searchInput?.value.toLowerCase().trim() ?? '';
        const category = categoryFilter?.value ?? 'all';
        const showDrafts = draftToggle?.checked ?? false;
        const sorter = sorters[sortSelect?.value] ?? sorters['title-asc'];
        let visibleCount = 0;

        const sortedCards = [...cards].sort(sorter);
        sortedCards.forEach(card => grid?.appendChild(card));

        sortedCards.forEach(card => {
            const matchesCategory = category === 'all' || card.dataset.category === category;
            const matchesSearch = !query || card.textContent.toLowerCase().includes(query);
            const matchesVisibility = showDrafts || card.dataset.visibility === 'public';
            const isVisible = matchesCategory && matchesSearch && matchesVisibility;
            card.classList.toggle('hidden', !isVisible);
            if (isVisible) visibleCount += 1;
        });

        if (countLabel) countLabel.textContent = String(visibleCount);
    }

    searchInput?.addEventListener('input', updateCourses);
    categoryFilter?.addEventListener('change', updateCourses);
    sortSelect?.addEventListener('change', updateCourses);
    draftToggle?.addEventListener('change', updateCourses);
    updateCourses();
</script>
