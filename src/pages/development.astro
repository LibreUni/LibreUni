---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getLessonsByCourse } from '../utils/lessons';
import smokeRecords from '../data/course-quality.json';
const COMPONENTS = ['Quiz', 'CodeRunner', 'CodeExercise', 'CaseStudy'];

function analyzeLesson(body: string, data: any) {
  const components = Object.fromEntries(COMPONENTS.map((name) => [name, (body.match(new RegExp(`<${name}\\b`, 'g')) || []).length]));
  return { words: (body.match(/\w+/g) || []).length, components };
}

const courses = await getCollection('courses');
const lessons = await getCollection('lessons');
const lessonsByCourse = await getLessonsByCourse(lessons);
const courseMetrics = courses
  .map((course) => {
    const courseLessons = lessonsByCourse[course.id] ?? [];
    const modules = new Map<string, { lessons: number; characters: number }>();

    for (const lesson of courseLessons) {
      const module = modules.get(lesson.data.module ?? 'Overview') ?? { lessons: 0, characters: 0 };
      module.lessons += 1;
      module.characters += lesson.body.length;
      modules.set(lesson.data.module ?? 'Overview', module);
    }

    const characters = [...modules.values()].reduce((total, module) => total + module.characters, 0);
    const analyzedLessons = courseLessons.map(l => analyzeLesson(l.body, l.data));
    const componentCounts = Object.fromEntries(COMPONENTS.map(name => [name, analyzedLessons.reduce((sum, l) => sum + (l.components[name] || 0), 0)]));
    const smokeTest = (smokeRecords as Record<string, any>)[course.id]?.smokeTest ?? { status: 'not-run', errors: [] };

    return {
      course,
      characters,
      lessons: courseLessons.length,
      modules: modules.size,
      charactersPerLesson: courseLessons.length ? Math.round(characters / courseLessons.length) : 0,
      charactersPerModule: modules.size ? Math.round(characters / modules.size) : 0,
      lessonsPerModule: modules.size ? Number((courseLessons.length / modules.size).toFixed(1)) : 0,
      averageWords: courseLessons.length ? Math.round(analyzedLessons.reduce((sum, l) => sum + l.words, 0) / courseLessons.length) : 0,
      componentCounts,
      smokeStatus: smokeTest.status,
      smokeErrors: smokeTest.errors ?? [],
    };
  })
  .sort((a, b) => a.course.data.title.localeCompare(b.course.data.title));

const formatNumber = new Intl.NumberFormat('en-US');
const courseData = courseMetrics.map(m => ({
  id: m.course.id,
  title: m.course.data.title,
  status: m.course.data.status,
  characters: m.characters,
  lessons: m.lessons,
  modules: m.modules,
  charactersPerLesson: m.charactersPerLesson,
  charactersPerModule: m.charactersPerModule,
  lessonsPerModule: m.lessonsPerModule,
  averageWords: m.averageWords,
  componentCounts: m.componentCounts,
  smokeStatus: m.smokeStatus,
  smokeErrors: m.smokeErrors,
}));
const encoded = Buffer.from(JSON.stringify(courseData)).toString('base64');
---

<Layout title="Development - LibreUni">
  <main id="ml-dashboard" class="flex-1 bg-light-bg dark:bg-dark-bg" data-courses={encoded}>
    <section class="border-b border-light-border bg-white px-6 py-16 dark:border-dark-border dark:bg-dark-bg md:px-8 md:py-24">
      <div class="mx-auto max-w-7xl">
        <p class="text-xs font-black uppercase tracking-[0.25em] text-primary">Development</p>
        <h1 class="mt-4 text-5xl font-black uppercase leading-none tracking-tight text-light-text dark:text-dark-text md:text-7xl">Course Metrics and Smoke Tests</h1>
        <p class="mt-6 max-w-3xl text-lg font-medium leading-relaxed text-light-muted dark:text-dark-muted">Generated UX findings, course metrics, and code smoke-test failures for maintaining LibreUni.</p>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-12 md:px-8 md:py-16">
      <div class="flex flex-wrap items-end justify-between gap-6">
