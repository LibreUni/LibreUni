    <section class="border-t border-light-border bg-white px-6 py-12 dark:border-dark-border dark:bg-dark-bg md:px-8 md:py-16">
      <div class="mx-auto max-w-7xl">
        <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Interactive Tools</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-light-text dark:text-dark-text">Developer Tools & Inspector</h2>
