            <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Scree Plot</p>
            <p class="mt-1 text-sm text-light-muted dark:text-dark-muted">Variance explained per principal component</p>
            <svg id="scree-plot" class="mt-4 hidden h-64 w-full" viewBox="0 0 800 260" role="img" aria-label="PCA scree plot showing variance explained by each component"></svg>
            <p id="scree-summary" class="mt-2 text-xs leading-relaxed text-light-muted dark:text-dark-muted"></p>
          </div>

          <div class="rounded-2xl border border-light-border bg-white p-6 dark:border-dark-border dark:bg-dark-bg">
            <div class="flex flex-wrap items-end justify-between gap-2">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">Component Space</p>
