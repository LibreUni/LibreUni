              </div>
              <div class="flex gap-3 text-xs font-bold text-light-text dark:text-dark-text">
                <label>X <select id="chart-x" class="ml-1 rounded-lg border border-light-border bg-light-bg px-2 py-1 dark:border-dark-border dark:bg-dark-surface"><option value="pca1">PCA 1</option><option value="characters">Total characters</option><option value="lessons">Lessons</option><option value="modules">Modules</option><option value="charactersPerLesson">Chars / lesson</option><option value="charactersPerModule">Chars / module</option><option value="lessonsPerModule">Lessons / module</option><option value="averageWords">Avg words</option></select></label>
                <label>Y <select id="chart-y" class="ml-1 rounded-lg border border-light-border bg-light-bg px-2 py-1 dark:border-dark-border dark:bg-dark-surface"><option value="pca2">PCA 2</option><option value="characters">Total characters</option><option value="lessons">Lessons</option><option value="modules">Modules</option><option value="charactersPerLesson">Chars / lesson</option><option value="charactersPerModule">Chars / module</option><option value="lessonsPerModule">Lessons / module</option><option value="averageWords">Avg words</option></select></label>
              </div>
            </div>
            <svg id="scatter-plot" class="mt-4 hidden h-64 w-full" viewBox="0 0 800 300" role="img" aria-label="Course metrics scatter plot on PCA axes"></svg>
            <p id="chart-tooltip" class="mt-1 text-xs font-bold text-light-muted dark:text-dark-muted"></p>
          </div>
        </div>

        <p id="chart-summary" class="mt-6 text-sm leading-relaxed text-light-muted dark:text-dark-muted"></p>
