    </section>

    <section class="border-t border-light-border bg-light-surface/50 px-6 py-12 dark:border-dark-border dark:bg-dark-surface/40 md:px-8 md:py-16">
      <div class="mx-auto max-w-7xl">
        <p class="text-xs font-black uppercase tracking-[0.2em] text-primary">PCA</p>
