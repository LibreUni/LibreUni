---
import { getCollection, type CollectionEntry, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CourseSidebar from '../../components/CourseSidebar.astro';
import { ChevronLeft, ChevronRight, Maximize2, Minimize2 } from 'lucide-react';
import { getLessonsByCourse, type OrderedLesson } from '../../utils/lessons';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  const courses = await getCollection('courses');
  
  // Pre-calculate course data to avoid expensive lookups per page
  const courseMap = Object.fromEntries(courses.map(c => [c.id, c]));
  
  const courseLessonsMap = await getLessonsByCourse(lessons);

  const paths: any[] = [];
  for (const courseId in courseLessonsMap) {
    const courseLessons = courseLessonsMap[courseId];
    const course = courseMap[courseId];
    
    courseLessons.forEach((lesson, index) => {
      paths.push({
        params: { slug: lesson.slug },
        props: { 
          lesson,
          course, // Pass pre-fetched course data
          courseLessons,
          nextLesson: courseLessons[index + 1] ? {
            slug: courseLessons[index + 1].slug,
            data: { title: courseLessons[index + 1].data.title }
          } : null,
          prevLesson: courseLessons[index - 1] ? {
            slug: courseLessons[index - 1].slug,
            data: { title: courseLessons[index - 1].data.title }
          } : null
        },
      });
    });
  }
  return paths;
}

interface Props {
  lesson: CollectionEntry<'lessons'>;
  course: CollectionEntry<'courses'>;
  courseLessons: OrderedLesson[];
  nextLesson: { slug: string, data: { title: string } } | null;
  prevLesson: { slug: string, data: { title: string } } | null;
}

const { lesson, course, courseLessons, nextLesson, prevLesson } = Astro.props;
const { Content } = await lesson.render();
---

<Layout title={`${lesson.data.title} - ${course?.data.title}`}>
  <CourseSidebar courseId={lesson.data.course} currentSlug={lesson.slug} lessons={courseLessons} />

  <main class="flex-1 bg-light-bg dark:bg-dark-bg min-w-0">
        <div id="lesson-container" data-lu-source={`src/content/lessons/${lesson.slug}.mdx; rendered by src/pages/lessons/[...slug].astro:60`} class="max-w-5xl mx-auto px-6 md:px-10 py-10 md:py-16">
        <div class="mb-10 md:mb-12">
            <div class="flex items-center justify-between mb-6">
                <div class="flex min-w-0 items-center gap-2">
                    <a href={`${import.meta.env.BASE_URL}courses/${lesson.data.course}`} class="inline-flex min-h-11 items-center text-[11px] font-black uppercase tracking-[0.14em] text-primary hover:opacity-80 transition-opacity">{course?.data.title}</a>
                    <span class="text-light-muted dark:text-dark-muted">/</span>
                    <span class="truncate text-[11px] font-black uppercase tracking-[0.14em] text-light-muted dark:text-dark-muted">{lesson.data.module || 'Intro'}</span>
                </div>
                
                <button 
                    id="view-toggle"
                    class="hidden min-h-11 min-w-11 md:flex items-center justify-center rounded-xl bg-light-accent/5 dark:bg-dark-accent/5 border border-light-border dark:border-dark-border text-light-muted dark:text-dark-muted hover:text-light-text dark:hover:text-dark-text transition-all hover:bg-light-accent/10 dark:hover:bg-dark-accent/10"
                    title="Toggle Expanded View"
                >
                    <span id="max-icon"><Maximize2 size={16} /></span>
                    <span id="min-icon" class="hidden"><Minimize2 size={16} /></span>
                </button>
            </div>
            <h1 class="text-4xl md:text-6xl font-black text-light-text dark:text-dark-text mb-6 tracking-tight leading-[1.1] md:leading-none break-words">{lesson.data.title}</h1>
            <div class="h-1.5 w-16 md:w-20 bg-primary rounded-full"></div>
            <button id="sidebar-toggle" class="btn-primary mt-6 min-h-11 !rounded-xl !px-4 !py-2 text-sm md:hidden">Course contents</button>
        </div>

        <!-- Navigation Buttons Top -->
        <div class="flex justify-between items-center mb-10 md:mb-12 border-b border-light-border dark:border-dark-border pb-6 md:pb-8 gap-4">
            {prevLesson ? (
                <a href={`${import.meta.env.BASE_URL}lessons/${prevLesson.slug}`} aria-label={`Previous lesson: ${prevLesson.data.title}`} class="min-h-11 bg-light-surface dark:bg-dark-surface hover:bg-primary/5 hover:text-primary dark:hover:text-primary text-light-text dark:text-dark-text px-4 md:px-8 py-3 rounded-2xl font-bold transition-all flex items-center gap-2 text-[10px] md:text-sm border border-light-border dark:border-dark-border shadow-sm hover:shadow-xl hover:-translate-y-1">
                   <ChevronLeft size={16} className="md:w-[18px] md:h-[18px]" /> <span class="hidden xs:inline">PREVIOUS</span>
                </a>
            ) : <div />}
            
            {nextLesson ? (
                <a href={`${import.meta.env.BASE_URL}lessons/${nextLesson.slug}`} aria-label={`Next lesson: ${nextLesson.data.title}`} class="min-h-11 bg-primary text-white px-6 md:px-10 py-3 rounded-2xl font-bold transition-all flex items-center gap-2 text-[10px] md:text-sm shadow-xl shadow-primary/20 hover:scale-105 hover:-translate-y-1">
                    <span>Next</span> <ChevronRight size={16} className="md:w-[18px] md:h-[18px]" />
                </a>
            ) : <div />}
        </div>

        <article data-lu-source={`src/content/lessons/${lesson.slug}.mdx; rendered by src/pages/lessons/[...slug].astro:98`} class="prose prose-slate dark:prose-invert max-w-none
            prose-headings:text-light-text dark:prose-headings:text-dark-text prose-headings:font-black prose-headings:tracking-tight
            prose-p:text-light-text dark:prose-p:text-dark-text prose-p:leading-relaxed prose-p:font-medium text-lg
            prose-code:before:content-none prose-code:after:content-none
            prose-pre:rounded-3xl prose-pre:shadow-2xl
            prose-strong:text-light-text dark:prose-strong:text-dark-text prose-strong:font-black
            prose-li:text-light-text dark:prose-li:text-dark-text prose-li:font-medium
            prose-img:rounded-[2rem] prose-img:shadow-2xl">
            <Content />
        </article>

        <!-- Navigation Buttons Bottom -->
        <div class="flex flex-col sm:flex-row justify-between items-center mt-20 pt-10 border-t border-light-border dark:border-dark-border gap-6">
            {prevLesson ? (
                <div class="flex flex-col gap-2 w-full sm:w-auto">
                    <span class="text-[10px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em] px-2 text-center sm:text-left">Previous Module</span>
                    <a href={`${import.meta.env.BASE_URL}lessons/${prevLesson.slug}`} class="bg-light-surface dark:bg-dark-surface text-light-text dark:text-dark-text px-10 py-6 rounded-[2rem] font-black transition-all flex items-center justify-center gap-4 text-lg border border-light-border dark:border-dark-border hover:bg-primary/5 hover:text-primary dark:hover:text-primary group shadow-sm hover:shadow-2xl">
                       <ChevronLeft size={24} /> {prevLesson.data.title}
                    </a>
                </div>
            ) : <div />}

            <div class="flex flex-col items-center gap-4">
                <button 
                  id="mark-completed"
                  class="group flex items-center gap-3 px-8 py-5 bg-emerald-500/10 hover:bg-emerald-500 text-emerald-600 dark:text-emerald-400 hover:text-white border-2 border-emerald-500 rounded-3xl font-black text-sm uppercase tracking-widest transition-all hover:scale-105 active:scale-95 active:bg-emerald-600"
                >
                  <span id="complete-text">Mark as Completed</span>
                  <div id="complete-icon" class="w-6 h-6 rounded-full border-2 border-current flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="hidden group-hover:block transition-all"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                </button>
            </div>
            
            {nextLesson ? (
                <div class="flex flex-col gap-2 w-full sm:w-auto items-center sm:items-end">
                    <span class="text-[10px] font-black text-light-muted dark:text-dark-muted uppercase tracking-[0.2em] px-2 text-center sm:text-right">Next Module</span>
                    <a href={`${import.meta.env.BASE_URL}lessons/${nextLesson.slug}`} class="bg-primary text-white px-12 py-6 rounded-[2rem] font-black transition-all flex items-center justify-center gap-4 text-xl shadow-2xl shadow-primary/20 hover:scale-105 active:scale-95 group">
                        {nextLesson.data.title} <ChevronRight size={24} className="group-hover:translate-x-2 transition-transform"/>
                    </a>
                </div>
            ) : (
                <a href={import.meta.env.BASE_URL} class="bg-primary text-white px-12 py-6 rounded-[2rem] font-black transition-all hover:scale-105 active:scale-95 uppercase tracking-widest text-sm shadow-2xl shadow-primary/30">
                    Finish Course
                </a>
            )}
        </div>
    </div>
  </main>
</Layout>

<script is:inline>
  // Immediate execution to prevent flash and animation on load
  (function() {
    const container = document.getElementById('lesson-container');
    const isExpanded = localStorage.getItem('lesson-expanded') === 'true';
    const maxIcon = document.getElementById('max-icon');
    const minIcon = document.getElementById('min-icon');
    
    if (isExpanded && container) {
      container.classList.remove('max-w-4xl');
      container.classList.add('max-w-7xl');
      if (maxIcon) maxIcon.classList.add('hidden');
      if (minIcon) minIcon.classList.remove('hidden');
    }
    
    // Add transition ONLY after initial state is set to avoid load animation
    setTimeout(() => {
        if (container) container.classList.add('transition-all', 'duration-500', 'ease-in-out');
    }, 10);
  })();
</script>

<script>
  const toggleBtn = document.getElementById('view-toggle');
  const container = document.getElementById('lesson-container');
  const maxIcon = document.getElementById('max-icon');
  const minIcon = document.getElementById('min-icon');

  toggleBtn?.addEventListener('click', () => {
    const isExpanded = container?.classList.contains('max-w-7xl');
    
    if (isExpanded) {
      container?.classList.remove('max-w-7xl');
      container?.classList.add('max-w-4xl');
      maxIcon?.classList.remove('hidden');
      minIcon?.classList.add('hidden');
      localStorage.setItem('lesson-expanded', 'false');
    } else {
      container?.classList.remove('max-w-4xl');
      container?.classList.add('max-w-7xl');
      maxIcon?.classList.add('hidden');
      minIcon?.classList.remove('hidden');
      localStorage.setItem('lesson-expanded', 'true');
    }
  });
</script>

<script is:inline define:vars={{ slug: lesson.slug, courseId: lesson.data.course }}>
  // Progress tracking logic
  const completeBtn = document.getElementById('mark-completed');
  const completeText = document.getElementById('complete-text');
  const completeIcon = document.getElementById('complete-icon');
  
  const completedKey = `completed-${slug}`;
  const lastVisitedKey = `last-visited-${courseId}`;

  // Mark as last visited
  localStorage.setItem(lastVisitedKey, slug);

  function updateButtonState() {
    if (localStorage.getItem(completedKey) === 'true') {
      completeBtn.classList.remove('bg-emerald-500/10', 'text-emerald-600', 'dark:text-emerald-400', 'border-emerald-500');
      completeBtn.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500');
      completeText.innerText = 'Completed';
      const checkSvg = completeIcon.querySelector('svg');
      if (checkSvg) {
        checkSvg.classList.remove('hidden', 'group-hover:block');
        checkSvg.classList.add('block');
      }
    }
  }

  updateButtonState();

  completeBtn?.addEventListener('click', () => {
    const isCompleted = localStorage.getItem(completedKey) === 'true';
    if (isCompleted) {
      localStorage.removeItem(completedKey);
      completeBtn.classList.add('bg-emerald-500/10', 'text-emerald-600', 'dark:text-emerald-400', 'border-emerald-500');
      completeBtn.classList.remove('bg-emerald-500', 'text-white', 'border-emerald-500');
      completeText.innerText = 'Mark as Completed';
      const checkSvg = completeIcon.querySelector('svg');
      if (checkSvg) {
        checkSvg.classList.add('hidden', 'group-hover:block');
        checkSvg.classList.remove('block');
      }
      // Dispatch event to update sidebar even when unmarking
      window.dispatchEvent(new CustomEvent('lesson-completed', { detail: { slug, completed: false } }));
    } else {
      localStorage.setItem(completedKey, 'true');
      updateButtonState();
      // Dispatch custom event for sidebar
      window.dispatchEvent(new CustomEvent('lesson-completed', { detail: { slug, completed: true } }));
    }
  });
</script>

<style is:global>
    /* Better defaults for code within the theme */
    .prose pre {
        @apply bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border shadow-sm !important;
        padding: 1.5rem !important;
        border-radius: 1.5rem !important;
    }
    .prose code {
        @apply text-primary font-bold !important;
    }
    /* Don't apply the inline code background to code inside pre tags */
    .prose pre code {
        background-color: transparent !important;
        color: inherit !important;
        padding: 0 !important;
    }
</style>
